---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const alleArtikler = await getCollection('sovn');

// Category config
const kategorier = [
  { id: 'vitenskap', label: 'Søvnvitenskap', emoji: '🔬', color: '#7B6FA0', desc: 'Hva skjer i kropp og hjerne når du sover?' },
  { id: 'hygiene', label: 'Søvnhygiene', emoji: '🌿', color: '#1D9E75', desc: 'Vaner og tiltak for bedre søvnkvalitet' },
  { id: 'lidelser', label: 'Søvnlidelser', emoji: '🩺', color: '#C07050', desc: 'Insomni, søvnapné og andre søvnproblemer' },
  { id: 'livsfaser', label: 'Livsfaser', emoji: '🌱', color: '#4A8BBF', desc: 'Søvn i graviditet, ungdom, aldring og sorg' },
  { id: 'produkter', label: 'Produkter & tips', emoji: '🛏️', color: '#B8960C', desc: 'Vektede tepper, søvnmasker og apper' },
  { id: 'psykologi', label: 'Søvnpsykologi', emoji: '🧠', color: '#9B7FBF', desc: 'Drømmer, stress og det ubevisste' },
];

// Group articles by category
const artiklerPerKategori = kategorier.map(kat => ({
  ...kat,
  artikler: alleArtikler.filter(a => a.data.kategori === kat.id),
})).filter(k => k.artikler.length > 0);
---

<Base tittel="Søvn — vitenskap, vaner og bedre netter" beskrivelse="Alt du trenger å vite om søvn: søvnfaser, søvnhygiene, søvnproblemer og sammenhengen mellom søvn og drømmer. Basert på forskning." canonicalUrl="https://drommeguiden.no/sovn">
  <div class="sovn-hub">
    <!-- Hero -->
    <section class="sovn-hero">
      <div class="sovn-hero-content">
        <span class="sovn-hero-label">NY SEKSJON</span>
        <h1 class="sovn-hero-title">Søvn</h1>
        <p class="sovn-hero-subtitle">
          Vitenskap, vaner og bedre netter — alt du trenger å vite om søvn, basert på forskning.
        </p>
        <p class="sovn-hero-count">{alleArtikler.length} artikler</p>
      </div>
      <div class="sovn-hero-orb sovn-hero-orb-1" aria-hidden="true"></div>
      <div class="sovn-hero-orb sovn-hero-orb-2" aria-hidden="true"></div>
    </section>

    <!-- Category grid -->
    <section class="sovn-categories">
      <div class="sovn-cat-grid">
        {kategorier.map(kat => (
          <a href={`#${kat.id}`} class="sovn-cat-card" style={`border-color: ${kat.color}22;`}>
            <span class="sovn-cat-emoji">{kat.emoji}</span>
            <h3 class="sovn-cat-label" style={`color: ${kat.color};`}>{kat.label}</h3>
            <p class="sovn-cat-desc">{kat.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Articles by category -->
    {artiklerPerKategori.map(kat => (
      <section class="sovn-section" id={kat.id}>
        <div class="sovn-section-header">
          <span class="sovn-section-emoji">{kat.emoji}</span>
          <h2 class="sovn-section-title" style={`color: ${kat.color};`}>{kat.label}</h2>
        </div>
        <div class="sovn-article-grid">
          {kat.artikler.map((art: any) => (
            <a href={`/sovn/${art.data.slug}`} class="sovn-article-card">
              {art.data.bilde && (
                <div class="sovn-article-img">
                  <img src={art.data.bilde} alt={art.data.tittel} loading="lazy" />
                </div>
              )}
              <div class="sovn-article-body">
                <span class="sovn-article-meta">{art.data.leseminutter} min lesetid</span>
                <h3 class="sovn-article-title">{art.data.tittel}</h3>
                <p class="sovn-article-desc">{art.data.kortbeskrivelse}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- Bridge to dreams -->
    <section class="sovn-bridge">
      <div class="sovn-bridge-inner">
        <h2 class="sovn-bridge-title">Søvn og drømmer henger sammen</h2>
        <p class="sovn-bridge-text">
          Drømmene skjer under REM-søvn — og søvnkvaliteten påvirker direkte hva du drømmer.
          Utforsk over 200 drømmesymboler i vår komplette drømmeguide.
        </p>
        <div class="sovn-bridge-links">
          <a href="/drommer" class="btn-primary">Utforsk drømmesymboler</a>
          <a href="/guider" class="btn-secondary">Les guidene</a>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .sovn-hub {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Hero */
  .sovn-hero {
    position: relative;
    background: linear-gradient(160deg, #0f1328 0%, #1a2340 40%, #0f2030 100%);
    border-radius: 24px;
    padding: 56px 32px;
    margin-bottom: 48px;
    overflow: hidden;
    text-align: center;
  }
  .sovn-hero-content {
    position: relative;
    z-index: 2;
  }
  .sovn-hero-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #1D9E75;
    font-weight: 600;
    display: inline-block;
    background: rgba(29, 158, 117, 0.12);
    padding: 4px 12px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 20px;
  }
  .sovn-hero-title {
    font-family: var(--font-heading);
    font-size: 56px;
    color: #f2ede6;
    margin-bottom: 16px;
    font-weight: 700;
  }
  @media (min-width: 768px) {
    .sovn-hero-title { font-size: 72px; }
  }
  .sovn-hero-subtitle {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.7);
    max-width: 520px;
    margin: 0 auto 16px;
  }
  .sovn-hero-count {
    font-size: 13px;
    color: rgba(242, 237, 230, 0.4);
  }
  .sovn-hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .sovn-hero-orb-1 {
    width: 300px;
    height: 300px;
    top: -80px;
    right: -80px;
    background: radial-gradient(circle, rgba(29, 158, 117, 0.15) 0%, transparent 70%);
  }
  .sovn-hero-orb-2 {
    width: 200px;
    height: 200px;
    bottom: -60px;
    left: -40px;
    background: radial-gradient(circle, rgba(123, 111, 160, 0.1) 0%, transparent 70%);
  }

  /* Category cards */
  .sovn-categories {
    margin-bottom: 56px;
  }
  .sovn-cat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .sovn-cat-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .sovn-cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 16px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid;
    border-radius: var(--border-radius-card);
    text-decoration: none;
    transition: var(--transition);
  }
  .sovn-cat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--box-shadow-hover);
    text-decoration: none;
  }
  .sovn-cat-emoji {
    font-size: 28px;
    margin-bottom: 10px;
  }
  .sovn-cat-label {
    font-family: var(--font-nav);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .sovn-cat-desc {
    font-size: 12px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  /* Article sections */
  .sovn-section {
    margin-bottom: 48px;
  }
  .sovn-section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .sovn-section-emoji {
    font-size: 22px;
  }
  .sovn-section-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    margin: 0;
    border: none;
    padding: 0;
  }

  .sovn-article-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sovn-article-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.7);
    border-radius: var(--border-radius-card);
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    text-decoration: none;
    transition: var(--transition);
  }
  @media (min-width: 640px) {
    .sovn-article-card {
      flex-direction: row;
    }
  }
  .sovn-article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--box-shadow-hover);
    text-decoration: none;
  }
  .sovn-article-img {
    width: 100%;
    height: 180px;
    flex-shrink: 0;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .sovn-article-img {
      width: 200px;
      height: auto;
    }
  }
  .sovn-article-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sovn-article-body {
    padding: 20px;
    flex: 1;
  }
  .sovn-article-meta {
    font-size: 12px;
    color: var(--color-text-muted);
    font-family: var(--font-nav);
  }
  .sovn-article-title {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--color-text-heading);
    margin: 8px 0;
    font-weight: 700;
    border: none;
    padding: 0;
  }
  .sovn-article-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Bridge section */
  .sovn-bridge {
    margin: 64px 0 24px;
  }
  .sovn-bridge-inner {
    text-align: center;
    padding: 48px 32px;
    background: linear-gradient(160deg, rgba(123, 111, 160, 0.08), rgba(192, 128, 112, 0.06));
    border: 1px solid rgba(123, 111, 160, 0.12);
    border-radius: 24px;
  }
  .sovn-bridge-title {
    font-family: var(--font-heading);
    font-size: 32px;
    color: var(--color-text-heading);
    margin-bottom: 12px;
    font-weight: 700;
  }
  .sovn-bridge-text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 540px;
    margin: 0 auto 24px;
  }
  .sovn-bridge-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
</style>
