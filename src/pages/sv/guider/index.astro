---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const guider = await getCollection('guider-sv');
const sortert = guider.sort((a, b) => b.data.dato.getTime() - a.data.dato.getTime());
---

<Base
  tittel="Guider om drömmar och drömtolkning"
  beskrivelse="Fördjupande guider om drömmar, drömtolkning, drömjournal och hur du förstår dina drömmar bättre."
  lang="sv"
  canonicalUrl="https://drommeguiden.no/sv/guider/"
  alternates={[
    { lang: 'nb', url: 'https://drommeguiden.no/guider/' },
    { lang: 'sv', url: 'https://drommeguiden.no/sv/guider/' },
  ]}
>
  <div class="guider-page">
    <div class="guider-header">
      <span class="guider-label">Djupdykningar</span>
      <h1 class="guider-title">Guider</h1>
      <p class="guider-subtitle">
        Fördjupande artiklar om drömmar, tolkning och det undermedvetna.
      </p>
    </div>

    {sortert.length === 0 ? (
      <p class="guider-empty">Svenska guider kommer snart.</p>
    ) : (
      <div class="guider-grid">
        {sortert.map((g) => (
          <a href={`/sv/guider/${g.data.slug}/`} class="guide-card">
            {g.data.bilde && (
              <div class="guide-card-img">
                <img src={g.data.bilde} alt={g.data.tittel} loading="lazy" />
              </div>
            )}
            <div class="guide-card-body">
              {g.data.leseminutter && <span class="guide-card-meta">{g.data.leseminutter} min läsning</span>}
              <h2 class="guide-card-title">{g.data.tittel}</h2>
              <p class="guide-card-desc">{g.data.kortbeskrivelse}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .guider-page { max-width: 900px; margin: 0 auto; }
  .guider-header { margin-bottom: 40px; }
  .guider-label {
    display: block; font-family: var(--font-nav); font-size: 11px; font-weight: 600;
    letter-spacing: 1.5px; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 10px;
  }
  .guider-title {
    font-family: var(--font-heading); font-size: 48px; color: var(--color-text-heading); font-weight: 400; margin-bottom: 12px;
  }
  .guider-subtitle { font-size: 16px; color: var(--color-text-muted); line-height: 1.6; }
  .guider-empty { padding: 64px 0; text-align: center; color: var(--color-text-muted); }
  .guider-grid { display: grid; gap: 16px; }
  .guide-card {
    display: flex; flex-direction: column; background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(123, 111, 160, 0.08); border-radius: 16px;
    overflow: hidden; text-decoration: none; transition: all 0.25s ease;
  }
  @media (min-width: 640px) { .guide-card { flex-direction: row; } }
  .guide-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(26, 31, 58, 0.06);
    text-decoration: none; border-color: rgba(123, 111, 160, 0.2);
  }
  .guide-card-img { width: 100%; height: 180px; overflow: hidden; flex-shrink: 0; }
  @media (min-width: 640px) { .guide-card-img { width: 220px; height: auto; } }
  .guide-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .guide-card-body { padding: 22px; flex: 1; }
  .guide-card-meta { font-size: 12px; color: var(--color-text-muted); font-family: var(--font-nav); font-weight: 500; }
  .guide-card-title { font-family: var(--font-heading); font-size: 22px; margin: 8px 0; border: none; padding: 0; font-weight: 400; }
  .guide-card-desc { font-size: 14px; line-height: 1.6; color: var(--color-text-muted); }
</style>
