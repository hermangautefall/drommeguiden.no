---
import { getCollection, render } from 'astro:content';
import Guide from '../../layouts/Guide.astro';
import { pathFor } from '../../i18n/utils';

export async function getStaticPaths() {
  const guider = await getCollection('guider');
  return guider.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const alternates: { lang: 'nb' | 'sv'; url: string }[] = [
  { lang: 'nb', url: `https://drommeguiden.no${pathFor('nb', 'guider', entry.data.slug)}` },
];
if (entry.data.sv_slug) {
  alternates.push({
    lang: 'sv',
    url: `https://drommeguiden.no${pathFor('sv', 'guider', entry.data.sv_slug)}`,
  });
}
---

<Guide
  tittel={entry.data.tittel}
  kortbeskrivelse={entry.data.kortbeskrivelse}
  slug={entry.data.slug}
  leseminutter={entry.data.leseminutter}
  dato={entry.data.dato}
  bilde={entry.data.bilde}
  lang="nb"
  alternates={alternates}
>
  <Content />
</Guide>
