---
import Base from '../layouts/Base.astro';
import DrommensDag from '../components/DrommensDag.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import { getCollection } from 'astro:content';

const drommer = await getCollection('drommer');
const guider = await getCollection('guider');

// 6 featured symbols — chosen for strong images
const featuredSlugs = ['slange', 'hav', 'eksen', 'tann', 'brann', 'flyging'];
const featuredSymboler = featuredSlugs
  .map(slug => drommer.find(d => d.data.slug === slug))
  .filter(Boolean);

// Categories with symbol counts
const kategorier = [
  { slug: 'dyr', tittel: 'Dyr', emoji: '🐾' },
  { slug: 'vann', tittel: 'Vann', emoji: '🌊' },
  { slug: 'kropp', tittel: 'Kropp', emoji: '🫀' },
  { slug: 'steder', tittel: 'Steder', emoji: '🏠' },
  { slug: 'hendelser', tittel: 'Hendelser', emoji: '⚡' },
  { slug: 'mennesker', tittel: 'Mennesker', emoji: '👤' },
  { slug: 'natur', tittel: 'Natur', emoji: '🌿' },
  { slug: 'gjenstander', tittel: 'Gjenstander', emoji: '🔑' },
  { slug: 'aandelig', tittel: 'Åndelig', emoji: '✨' },
];

const kategorierMedAntall = kategorier.map(kat => ({
  ...kat,
  antall: drommer.filter(d => d.data.kategori === kat.slug).length,
}));
---

<Base
  tittel="Drømmeguiden"
  beskrivelse="Finn ut hva drømmene dine betyr. Norges mest komplette guide til drømmesymboler og drømmetolkning."
>

  <!-- 1. HERO with starfield -->
  <section class="hero-section">
    <!-- Starfield background -->
    <div class="starfield" aria-hidden="true">
      <div class="star" style="top:8%;left:12%;--duration:4s;--delay:0s;"></div>
      <div class="star" style="top:15%;left:78%;--duration:3s;--delay:1.2s;"></div>
      <div class="star" style="top:25%;left:45%;--duration:5s;--delay:0.5s;"></div>
      <div class="star" style="top:40%;left:90%;--duration:3.5s;--delay:2s;"></div>
      <div class="star" style="top:55%;left:20%;--duration:4.5s;--delay:0.8s;"></div>
      <div class="star" style="top:70%;left:65%;--duration:3s;--delay:1.5s;"></div>
      <div class="star" style="top:12%;left:35%;--duration:6s;--delay:0.3s;"></div>
      <div class="star" style="top:85%;left:50%;--duration:4s;--delay:2.5s;"></div>
      <div class="star" style="top:30%;left:8%;--duration:5s;--delay:1s;"></div>
      <div class="star" style="top:65%;left:85%;--duration:3.5s;--delay:0.7s;"></div>
      <div class="star" style="top:48%;left:55%;--duration:4.5s;--delay:1.8s;"></div>
      <div class="star" style="top:5%;left:60%;--duration:3s;--delay:2.2s;"></div>
      <div class="star" style="top:78%;left:30%;--duration:5.5s;--delay:0.4s;"></div>
      <div class="star" style="top:20%;left:92%;--duration:4s;--delay:1.6s;"></div>
      <div class="star" style="top:90%;left:15%;--duration:3.5s;--delay:0.9s;"></div>
    </div>

    <div class="hero-inner">
      <!-- Left column: text + search -->
      <div class="hero-text">
        <p class="hero-label">✦ DRØMMEGUIDEN.NO</p>
        <h1 class="hero-title">Hva drømte du<br />i natt?</h1>
        <p class="hero-subtitle">
          Norges mest komplette guide til drømmesymboler og drømmetolkning. Forstå hva drømmene dine prøver å fortelle deg.
        </p>

        <!-- Search field -->
        <div class="hero-search-wrapper">
          <div class="hero-search-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <input
            type="text"
            id="sok"
            placeholder="Søk etter et drømmesymbol..."
            autocomplete="off"
            class="hero-search-input"
          />
          <div
            id="sok-resultater"
            class="hero-search-results hidden"
          ></div>
        </div>

        <div class="hero-stats">
          <span>{drommer.length} symboler</span>
          <span class="hero-stats-dot">·</span>
          <span>{kategorier.length} kategorier</span>
          <span class="hero-stats-dot">·</span>
          <span>{guider.length} guider</span>
        </div>
      </div>

      <!-- Right column: DrommensDag -->
      <div class="hero-dag-wrapper">
        <DrommensDag />
      </div>
    </div>
  </section>

  <!-- 2. QUOTE STRIP -->
  <div class="quote-strip">
    <div class="quote-track">
      <span class="quote-item">« Drømmer er sjelens billedspråk »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« I drømmer begynner ansvaret »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« Natten vet hva dagen har glemt »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« En uutforsket drøm er som et ulest brev »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« Drømmer er sjelens billedspråk »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« I drømmer begynner ansvaret »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« Natten vet hva dagen har glemt »</span>
      <span class="quote-dot">✦</span>
      <span class="quote-item">« En uutforsket drøm er som et ulest brev »</span>
      <span class="quote-dot">✦</span>
    </div>
  </div>

  <!-- 3. POPULÆRE SYMBOLER — now with images -->
  <section class="section-block">
    <div class="section-header">
      <h2>Populære drømmesymboler</h2>
      <a href="/drommer" class="section-link">Se alle symboler →</a>
    </div>
    <div class="symbols-grid">
      {featuredSymboler.map((d) => d && (
        <a href={`/drommer/${d.data.slug}`} class="symbol-card">
          {d.data.bilde ? (
            <div class="symbol-card-image">
              <img src={d.data.bilde} alt={d.data.tittel} loading="lazy" />
              <div class="symbol-card-image-overlay"></div>
            </div>
          ) : (
            <div class="symbol-card-image symbol-card-image-fallback"></div>
          )}
          <div class="symbol-card-body">
            <h3 class="symbol-card-title">
              {d.data.tittel.replace(/ — hva betyr det\?/, '').replace('Drømmer om ', '')}
            </h3>
            <p class="symbol-card-desc">{d.data.kortbeskrivelse}</p>
            <span class="symbol-card-cta">Les tolkning →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider"></div>

  <!-- 4. KATEGORIER -->
  <section class="section-block">
    <div class="section-header">
      <h2>Utforsk etter kategori</h2>
    </div>
    <div class="categories-grid">
      {kategorierMedAntall.map((kat) => (
        <a href={`/kategori/${kat.slug}`} class="category-card">
          <span class="category-emoji">{kat.emoji}</span>
          <div>
            <span class="category-title">{kat.tittel}</span>
            <span class="category-count">{kat.antall} symboler</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider"></div>

  <!-- 5. GUIDER -->
  {guider.length > 0 && (
    <section class="section-block">
      <div class="section-header">
        <h2>Guider om drømmer</h2>
        <a href="/guider" class="section-link">Alle guider →</a>
      </div>
      <div class="guides-grid">
        {guider.slice(0, 4).map((g) => (
          <a href={`/guider/${g.data.slug}`} class="guide-card">
            <div class="guide-left">
              {g.data.bilde ? (
                <img src={g.data.bilde} alt={g.data.tittel} class="guide-img" loading="lazy" />
              ) : (
                <div class="guide-placeholder"></div>
              )}
            </div>
            <div class="guide-right">
              <h3 class="guide-title">{g.data.tittel}</h3>
              <p class="guide-desc">{g.data.kortbeskrivelse}</p>
              {g.data.leseminutter && (
                <span class="guide-meta">{g.data.leseminutter} min lesetid</span>
              )}
            </div>
          </a>
        ))}
      </div>
      {guider.length > 4 && (
        <div style="text-align: center; margin-top: 24px;">
          <a href="/guider" class="btn-secondary">Se alle {guider.length} guider</a>
        </div>
      )}
    </section>
  )}

  <!-- 6. NYHETSBREV CTA -->
  <section class="section-block">
    <NewsletterCTA />
  </section>

  <!-- Schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Drømmeguiden',
      url: 'https://drommeguiden.no',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://drommeguiden.no/?sok={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    })}
  />

  <!-- Search script -->
  <script define:vars={{ symboler: drommer.map((d) => ({ tittel: d.data.tittel, slug: d.data.slug, kortbeskrivelse: d.data.kortbeskrivelse })) }}>
    const sokInput = document.getElementById('sok');
    const resultaterDiv = document.getElementById('sok-resultater');

    if (sokInput && resultaterDiv) {
      sokInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        if (query.length < 2) {
          resultaterDiv.classList.add('hidden');
          resultaterDiv.innerHTML = '';
          return;
        }

        const treff = symboler.filter(
          (s) =>
            s.slug.includes(query) ||
            s.tittel.toLowerCase().includes(query) ||
            s.kortbeskrivelse.toLowerCase().includes(query)
        ).slice(0, 6);

        if (treff.length === 0) {
          resultaterDiv.classList.add('hidden');
          resultaterDiv.innerHTML = '';
          return;
        }

        resultaterDiv.innerHTML = treff
          .map(
            (s) =>
              `<a href="/drommer/${s.slug}" class="search-result-item">
                <span class="search-result-title">${s.tittel.replace(/ — hva betyr det\?/, '')}</span>
                <span class="search-result-desc">${s.kortbeskrivelse.slice(0, 80)}…</span>
              </a>`
          )
          .join('');
        resultaterDiv.classList.remove('hidden');
      });

      document.addEventListener('click', (e) => {
        if (!sokInput.contains(e.target) && !resultaterDiv.contains(e.target)) {
          resultaterDiv.classList.add('hidden');
        }
      });

      if (new URLSearchParams(window.location.search).has('fokus')) {
        sokInput.focus();
      }
    }
  </script>
</Base>

<style>
  /* ========== HERO ========== */
  .hero-section {
    position: relative;
    background: url('/bilder/hero-bg.jpg') center/cover no-repeat;
    margin: -2rem -1rem 0;
    padding: 72px 24px 80px;
    overflow: hidden;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(15,19,40,0.85) 0%, rgba(26,31,58,0.80) 30%, rgba(42,47,90,0.75) 60%, rgba(30,35,72,0.85) 100%);
    z-index: 0;
  }
  @media (min-width: 768px) {
    .hero-section {
      margin: -2rem calc(-50vw + 50%) 0;
      padding: 96px 48px 104px;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 380px;
      gap: 64px;
    }
  }

  .hero-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
    animation: fadeInUp 0.6s ease-out both;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 44px;
    line-height: 1.12;
    color: #f2ede6;
    margin-bottom: 24px;
    font-weight: 700;
    text-shadow: 0 0 60px rgba(123, 111, 160, 0.3);
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }
  @media (min-width: 768px) {
    .hero-title {
      font-size: 60px;
    }
  }

  .hero-subtitle {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.65);
    max-width: 460px;
    margin-bottom: 36px;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  .hero-search-wrapper {
    position: relative;
    max-width: 460px;
    margin-bottom: 28px;
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }

  .hero-search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(242, 237, 230, 0.4);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 16px 20px 16px 48px;
    border-radius: var(--border-radius-pill);
    border: 1px solid rgba(123, 111, 160, 0.3);
    background: rgba(255, 255, 255, 0.06);
    color: #f2ede6;
    font-size: 15px;
    font-family: var(--font-body);
    transition: var(--transition);
    backdrop-filter: blur(12px);
  }
  .hero-search-input::placeholder {
    color: rgba(242, 237, 230, 0.35);
  }
  .hero-search-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 24px rgba(123, 111, 160, 0.2);
  }

  .hero-search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    border-radius: var(--border-radius-card);
    overflow: hidden;
    z-index: 50;
    background: var(--color-bg-white);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }

  .hero-stats {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13px;
    color: rgba(242, 237, 230, 0.45);
    font-family: var(--font-nav);
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }
  .hero-stats-dot {
    color: var(--color-primary);
  }

  .hero-dag-wrapper {
    background: rgba(123, 111, 160, 0.1);
    border-radius: 20px;
    border: 1px solid rgba(123, 111, 160, 0.15);
    backdrop-filter: blur(16px);
    overflow: hidden;
    animation: fadeInUp 0.8s ease-out 0.3s both;
  }
  @media (max-width: 767px) {
    .hero-dag-wrapper {
      max-width: 380px;
      margin: 0 auto;
    }
  }

  /* ========== QUOTE STRIP ========== */
  .quote-strip {
    background: linear-gradient(135deg, var(--color-primary) 0%, #6a5f8e 100%);
    padding: 16px 0;
    overflow: hidden;
    margin: 0 -1rem;
  }
  @media (min-width: 768px) {
    .quote-strip {
      margin: 0 calc(-50vw + 50%);
    }
  }

  .quote-track {
    display: flex;
    gap: 32px;
    white-space: nowrap;
    animation: marquee 40s linear infinite;
  }

  .quote-item {
    font-family: var(--font-heading);
    font-size: 15px;
    font-style: italic;
    color: rgba(255, 255, 255, 0.85);
    flex-shrink: 0;
  }

  .quote-dot {
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    font-size: 10px;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ========== SECTIONS ========== */
  .section-block {
    padding: 72px 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 40px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .section-header h2 {
    font-family: var(--font-heading);
    font-size: 36px;
    color: var(--color-text-heading);
    margin: 0;
  }
  .section-link {
    font-family: var(--font-nav);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: var(--transition);
  }
  .section-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ========== SYMBOL CARDS with images ========== */
  .symbols-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (min-width: 768px) {
    .symbols-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .symbol-card {
    position: relative;
    border-radius: var(--border-radius-card);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--box-shadow-card);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    background: var(--color-bg-white);
  }
  .symbol-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(26, 31, 58, 0.15);
    text-decoration: none;
  }

  .symbol-card-image {
    position: relative;
    height: 180px;
    overflow: hidden;
  }
  .symbol-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .symbol-card:hover .symbol-card-image img {
    transform: scale(1.08);
  }
  .symbol-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(15, 19, 40, 0.15) 100%);
    pointer-events: none;
  }
  .symbol-card-image-fallback {
    background: linear-gradient(135deg, var(--color-bg-dark), #2a2f5a);
  }

  .symbol-card-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .symbol-card-title {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--color-text-heading);
    margin-bottom: 8px;
    font-weight: 700;
  }

  .symbol-card-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
    flex: 1;
  }

  .symbol-card-cta {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    opacity: 0;
    transform: translateX(-4px);
    transition: var(--transition);
  }
  .symbol-card:hover .symbol-card-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ========== CATEGORY CARDS ========== */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media (min-width: 640px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .category-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px;
    border-radius: var(--border-radius-card);
    background: var(--color-bg-white);
    border: 1px solid rgba(123, 111, 160, 0.1);
    text-decoration: none;
    transition: var(--transition);
  }
  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 32px rgba(123, 111, 160, 0.12);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .category-emoji {
    font-size: 32px;
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-light);
    border-radius: 14px;
    transition: var(--transition);
  }
  .category-card:hover .category-emoji {
    background: var(--color-primary-border);
    transform: scale(1.05);
  }

  .category-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .category-count {
    display: block;
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  /* ========== GUIDE CARDS ========== */
  .guides-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .guides-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .guide-card {
    display: flex;
    border-radius: var(--border-radius-card);
    overflow: hidden;
    background: var(--color-bg-white);
    box-shadow: var(--box-shadow-card);
    text-decoration: none;
    transition: var(--transition);
    min-height: 140px;
  }
  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(26, 31, 58, 0.12);
    text-decoration: none;
  }

  .guide-left {
    width: 140px;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
  }
  @media (min-width: 768px) {
    .guide-left {
      width: 160px;
    }
  }

  .guide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .guide-card:hover .guide-img {
    transform: scale(1.06);
  }

  .guide-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, #3a4070 100%);
  }

