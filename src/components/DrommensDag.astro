---
import { getCollection } from 'astro:content';

const symbolPool = [
  'slange', 'hav', 'falle', 'tann', 'brann', 'hund', 'katt', 'baby',
  'edderkopp', 'bjorn', 'bryllup', 'flyging', 'skog', 'storm', 'speil',
  'ulv', 'fjell', 'regn', 'hest', 'bil', 'hus', 'blod', 'naken',
  'eksen', 'gravid', 'engler', 'himmel', 'sol', 'mane', 'stjerner',
  'blomst', 'ring', 'kjaereste', 'fugl', 'mor', 'far', 'forfulgt',
  'kirke', 'sno', 'musikk', 'krig', 'dor', 'trapp', 'bro', 'tre',
  'elv', 'dans', 'hval', 'skip', 'ild', 'gull', 'troll', 'nordlys',
  'vikingskip', 'fjord', 'hytte', 'elg', 'laks', 'reinsdyr', 'lys'
];

const emojiMap: Record<string, string> = {
  slange: '🐍', hav: '🌊', falle: '🪂', tann: '🦷', brann: '🔥',
  hund: '🐕', katt: '🐈', baby: '👶', edderkopp: '🕷️', bjorn: '🐻',
  bryllup: '💒', flyging: '🕊️', 'morkt-rom': '🌑', skog: '🌲',
  storm: '⛈️', hender: '🤲', speil: '🪞', ulv: '🐺', fjell: '🏔️',
  regn: '🌧️', krage: '🦅', hest: '🐴', drukne: '🌀', bil: '🚗',
  skole: '🏫', sykehus: '🏥', hus: '🏠', blod: '🩸', naken: '😶',
  eksen: '💔', gravid: '🤰', engler: '😇', himmel: '☁️', sol: '☀️',
  mane: '🌙', stjerner: '⭐', blomst: '🌸', ring: '💍', kjaereste: '❤️',
  fugl: '🐦', orm: '🪱', ku: '🐄', gris: '🐷', mor: '👩', far: '👨',
  forfulgt: '🏃', do: '🕯️', fengsel: '🔒', kirke: '⛪', sno: '❄️',
  musikk: '🎵', krig: '⚔️',
  dor: '🚪', trapp: '🪜', bro: '🌉', tre: '🌳', elv: '🏞️',
  dans: '💃', hval: '🐋', skip: '⛵', ild: '🔥', gull: '✨',
  troll: '👹', nordlys: '🌌', vikingskip: '⚓', fjord: '🏔️',
  hytte: '🏡', elg: '🦌', laks: '🐟', reinsdyr: '🦌', lys: '🕯️'
};

const today = new Date();
const daysSinceEpoch = Math.floor(today.getTime() / (1000 * 60 * 60 * 24));
const todayIndex = daysSinceEpoch % symbolPool.length;
const todaySlug = symbolPool[todayIndex];
const todayEmoji = emojiMap[todaySlug] || '✨';

const alleSymboler = await getCollection('drommer');
const todaySymbol = alleSymboler.find(s => s.data.slug === todaySlug);

const symbolNavn = todaySymbol
  ? todaySymbol.data.tittel.replace(/ — hva betyr det\?/, '').replace('Drømmer om ', '')
  : todaySlug.replace(/-/g, ' ');
const symbolBeskrivelse = todaySymbol?.data.kortbeskrivelse || '';

const months = ['januar','februar','mars','april','mai','juni','juli','august','september','oktober','november','desember'];
const datoStr = `${today.getDate()}. ${months[today.getMonth()]} ${today.getFullYear()}`;
---

<div class="drommens-dag-wrapper">
  <p class="dag-label">✦ SYMBOLET I FOKUS I DAG</p>
  <div class="dag-emoji">{todayEmoji}</div>
  <h2 class="dag-navn">{symbolNavn}</h2>
  <p class="dag-beskrivelse">{symbolBeskrivelse}</p>
  <div class="dag-separator"></div>
  <a href={`/drommer/${todaySlug}`} class="dag-link hover:no-underline">
    Les full tolkning <span aria-hidden="true">&rarr;</span>
  </a>
  <p class="dag-dato">{datoStr}</p>
</div>

<style>
  .drommens-dag-wrapper {
    text-align: center;
    padding: 40px 24px;
    animation: fadeInUp 0.8s ease-out;
  }

  .dag-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.6);
    margin-bottom: 20px;
  }

  .dag-emoji {
    font-size: 80px;
    margin-bottom: 16px;
    animation: fadeInScale 1s ease-out 0.3s both;
  }

  .dag-navn {
    font-family: var(--font-heading);
    font-size: 32px;
    color: #f2ede6;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .dag-beskrivelse {
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(242, 237, 230, 0.75);
    line-height: 1.7;
    max-width: 360px;
    margin: 0 auto 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dag-separator {
    width: 48px;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 auto 20px;
  }

  .dag-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .dag-link:hover {
    opacity: 0.8;
  }

  .dag-dato {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 20px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInScale {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
