---
import { getCollection } from 'astro:content';

// Hent ALLE symboler ved build-tid og send som JSON til klienten
const alleSymboler = await getCollection('drommer');
const sorterteSymboler = [...alleSymboler].sort((a, b) => a.data.slug.localeCompare(b.data.slug));

// Bygg en kompakt liste med bare det klienten trenger
const symbolData = sorterteSymboler.map(s => ({
  slug: s.data.slug,
  navn: s.data.tittel.replace(/ — hva betyr det\?/, '').replace('Drømmer om ', ''),
  desc: s.data.kortbeskrivelse || '',
  bilde: s.data.bilde || '',
}));
---

<!-- Skjult data brukt av klient-scriptet -->
<script is:inline define:vars={{ symbolData }}>
  window.__drommensData = symbolData;
</script>

<div class="drommens-dag-wrapper" id="drommens-dag">
  <p class="dag-label">✦ SYMBOLET I FOKUS I DAG</p>
  <div class="dag-image dag-image-fallback" id="dag-image-container">✨</div>
  <h2 class="dag-navn" id="dag-navn">Laster...</h2>
  <p class="dag-beskrivelse" id="dag-beskrivelse"></p>
  <div class="dag-separator"></div>
  <a href="/drommer" class="dag-link hover:no-underline" id="dag-link">
    Les full tolkning <span aria-hidden="true">&rarr;</span>
  </a>
  <p class="dag-dato" id="dag-dato"></p>
</div>

<script is:inline>
  (function() {
    var data = window.__drommensData;
    if (!data || !data.length) return;

    // Beregn dagens symbol basert på brukerens lokale dato
    var now = new Date();
    var daysSinceEpoch = Math.floor(now.getTime() / (1000 * 60 * 60 * 24));
    var index = daysSinceEpoch % data.length;
    var symbol = data[index];

    // Oppdater DOM
    var navnEl = document.getElementById('dag-navn');
    var descEl = document.getElementById('dag-beskrivelse');
    var linkEl = document.getElementById('dag-link');
    var datoEl = document.getElementById('dag-dato');
    var imgContainer = document.getElementById('dag-image-container');

    if (navnEl) navnEl.textContent = symbol.navn;
    if (descEl) descEl.textContent = symbol.desc;
    if (linkEl) linkEl.href = '/drommer/' + symbol.slug;

    // Dato på norsk
    var months = ['januar','februar','mars','april','mai','juni','juli','august','september','oktober','november','desember'];
    if (datoEl) datoEl.textContent = now.getDate() + '. ' + months[now.getMonth()] + ' ' + now.getFullYear();

    // Bilde
    if (imgContainer && symbol.bilde) {
      imgContainer.className = 'dag-image';
      imgContainer.innerHTML = '<img src="' + symbol.bilde + '" alt="' + symbol.navn + '" loading="lazy" />';
    }
  })();
</script>

<style>
  .drommens-dag-wrapper {
    text-align: center;
    padding: 40px 24px;
    animation: fadeInUp 0.8s ease-out;
  }

  .dag-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.6);
    margin-bottom: 20px;
  }

  .dag-image {
    width: 100px;
    height: 100px;
    margin: 0 auto 16px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(242, 237, 230, 0.15);
    animation: fadeInScale 1s ease-out 0.3s both;
  }
  .dag-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dag-image-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    background: rgba(123, 111, 160, 0.15);
  }

  .dag-navn {
    font-family: var(--font-heading);
    font-size: 32px;
    color: #f2ede6;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .dag-beskrivelse {
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(242, 237, 230, 0.75);
    line-height: 1.7;
    max-width: 360px;
    margin: 0 auto 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dag-separator {
    width: 48px;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 auto 20px;
  }

  .dag-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .dag-link:hover {
    opacity: 0.8;
  }

  .dag-dato {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 20px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInScale {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
