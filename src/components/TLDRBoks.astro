---
import { defaultLang, type Lang } from '../i18n/config';

interface Props {
  tolkninger: string[];
  lang?: Lang;
}

const { tolkninger, lang = defaultLang } = Astro.props;
const label = lang === 'sv' ? 'Kort sammanfattat' : 'Kort oppsummert';
---

<div class="tldr-box">
  <div class="tldr-header">
    <span class="tldr-label">{label}</span>
  </div>
  <ul class="tldr-list">
    {tolkninger.map((tolkning) => (
      <li class="tldr-item">
        <span class="tldr-bullet" aria-hidden="true"></span>
        <span>{tolkning}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .tldr-box {
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(123, 111, 160, 0.15);
    border-radius: 16px;
    padding: 28px 28px 24px;
    margin-bottom: 40px;
    position: relative;
    overflow: hidden;
  }
  .tldr-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-accent) 100%);
    border-radius: 4px 0 0 4px;
  }

  .tldr-header {
    margin-bottom: 18px;
  }

  .tldr-label {
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .tldr-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .tldr-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-body);
  }

  .tldr-bullet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    margin-top: 10px;
  }
</style>
