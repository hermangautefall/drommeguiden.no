---
interface Props {
  tolkninger: string[];
}

const { tolkninger } = Astro.props;
---

<div class="tldr-box">
  <div class="tldr-header">
    <span class="tldr-icon">✦</span>
    <h2 class="tldr-title">Kort oppsummert</h2>
  </div>
  <ul class="tldr-list">
    {tolkninger.map((tolkning) => (
      <li class="tldr-item">
        <span class="tldr-bullet" aria-hidden="true"></span>
        <span>{tolkning}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .tldr-box {
    background: var(--color-bg-white);
    border: 1px solid var(--color-primary-border);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--border-radius-card);
    padding: 28px 28px 24px;
    margin-bottom: 40px;
    box-shadow: var(--box-shadow-card);
  }

  .tldr-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .tldr-icon {
    color: var(--color-primary);
    font-size: 14px;
  }

  .tldr-title {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--color-text-heading);
    font-weight: 700;
    margin: 0;
  }

  .tldr-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tldr-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-body);
  }

  .tldr-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    margin-top: 8px;
  }
</style>
