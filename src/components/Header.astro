---
import { languages, defaultLang, type Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { pathFor, homePath } from '../i18n/utils';

interface AlternateLink {
  lang: Lang;
  url: string;
}

interface Props {
  lang?: Lang;
  alternates?: AlternateLink[];
}

const { lang = defaultLang, alternates = [] } = Astro.props;
const t = useTranslations(lang);
const langConfig = languages[lang];

const navSymboler = pathFor(lang, 'drommer');
const navKategori = pathFor(lang, 'kategori');
const navGuider = pathFor(lang, 'guider');
const navSovn = pathFor(lang, 'sovn');
const navOmOss = pathFor(lang, 'omOss');
const navKontakt = pathFor(lang, 'kontakt');

// Language switcher: where each alternate language points
const langLinks = (Object.keys(languages) as Lang[]).map(l => {
  const alt = alternates.find(a => a.lang === l);
  return {
    code: l,
    flag: languages[l].flag,
    label: languages[l].label,
    shortLabel: languages[l].shortLabel,
    href: alt ? alt.url : homePath(l),
    current: l === lang,
  };
});
---

<header class="site-header">
  <nav class="header-nav">
    <!-- Logo -->
    <a href={homePath(lang)} class="header-logo hover:no-underline">
      <span class="header-moon" aria-hidden="true">🌙</span>
      <span class="header-brand">{langConfig.brand}</span>
    </a>

    <!-- Desktop navigation -->
    <div class="header-links">
      <a href={navSymboler} class="nav-link">{t('nav.symboler')}</a>
      <a href={navKategori} class="nav-link">{t('nav.kategorier')}</a>
      <a href={navGuider} class="nav-link">{t('nav.guider')}</a>
      <a href={navSovn} class="nav-link">{t('nav.sovn')}</a>
    </div>

    <!-- Desktop right side: language switcher + CTA -->
    <div class="header-right">
      <!-- Language switcher -->
      <div class="lang-switcher" id="lang-switcher">
        <button class="lang-btn" aria-haspopup="true" aria-expanded="false" aria-label={t('lang.bytt')}>
          <span class="lang-flag" aria-hidden="true">{langConfig.flag}</span>
          <span class="lang-code">{langConfig.shortLabel}</span>
          <svg class="lang-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="lang-menu" role="menu">
          {langLinks.map(l => (
            <a
              href={l.href}
              class={`lang-option ${l.current ? 'lang-option-current' : ''}`}
              role="menuitem"
              hreflang={languages[l.code].htmlLang}
            >
              <span class="lang-flag" aria-hidden="true">{l.flag}</span>
              <span>{l.label}</span>
              {l.current && <span class="lang-check" aria-hidden="true">✓</span>}
            </a>
          ))}
        </div>
      </div>

      <!-- Desktop CTA -->
      <a href={navSymboler} class="header-cta hover:no-underline">
        {t('cta.utforskSymboler')}
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      aria-label="Meny"
      class="hamburger-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="mobile-menu-hidden md:hidden mobile-menu-panel">
  <div class="mobile-menu-top">
    <a href={homePath(lang)} class="header-logo hover:no-underline">
      <span class="header-moon" aria-hidden="true">🌙</span>
      <span style="font-family: var(--font-heading); color: #f2ede6; font-size: 22px; font-weight: 400;">{langConfig.brand}</span>
    </a>
    <button id="mobile-close-btn" aria-label="Lukk meny" class="mobile-close">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class="mobile-menu-links">
    <a href={navSymboler} class="mobile-nav-link">{t('nav.symboler')}</a>
    <a href={navKategori} class="mobile-nav-link">{t('nav.kategorier')}</a>
    <a href={navGuider} class="mobile-nav-link">{t('nav.guider')}</a>
    <a href={navSovn} class="mobile-nav-link">{t('nav.sovn')}</a>
    <div class="mobile-divider"></div>
    <a href={navOmOss} class="mobile-nav-link mobile-nav-link-small">{t('nav.omOss')}</a>
    <a href={navKontakt} class="mobile-nav-link mobile-nav-link-small">{t('nav.kontakt')}</a>
    <div class="mobile-divider"></div>
    <div class="mobile-lang-row">
      {langLinks.map(l => (
        <a
          href={l.href}
          class={`mobile-lang-chip ${l.current ? 'mobile-lang-chip-current' : ''}`}
          hreflang={languages[l.code].htmlLang}
        >
          <span aria-hidden="true">{l.flag}</span>
          <span>{l.label}</span>
        </a>
      ))}
    </div>
  </div>
  <div class="mobile-menu-orb" aria-hidden="true"></div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(245, 240, 236, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(123, 111, 160, 0.08);
  }

  .header-nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 8px;
  }
  @media (min-width: 768px) {
    .header-nav {
      padding: 0 24px;
    }
  }

  /* Logo */
  .header-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .header-moon {
    font-size: 20px;
  }
  .header-brand {
    font-family: var(--font-heading);
    font-size: 21px;
    font-weight: 400;
    color: var(--color-text-heading);
    letter-spacing: -0.3px;
  }

  /* Nav links */
  .header-links {
    display: none;
    align-items: center;
    gap: 2px;
  }
  @media (min-width: 768px) {
    .header-links {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-nav);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 7px 16px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-text-heading);
    background: rgba(123, 111, 160, 0.07);
    text-decoration: none;
  }

  /* Right side: lang switcher + CTA */
  .header-right {
    display: none;
    align-items: center;
    gap: 10px;
  }
  @media (min-width: 768px) {
    .header-right {
      display: flex;
    }
  }

  /* Language switcher */
  .lang-switcher {
    position: relative;
  }
  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid rgba(123, 111, 160, 0.15);
    border-radius: var(--border-radius-pill);
    padding: 6px 12px;
    font-family: var(--font-nav);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-heading);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .lang-btn:hover {
    background: rgba(123, 111, 160, 0.07);
    border-color: rgba(123, 111, 160, 0.25);
  }
  .lang-flag {
    font-size: 14px;
  }
  .lang-chevron {
    opacity: 0.6;
    transition: transform 0.2s ease;
  }
  .lang-switcher.open .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: rgba(245, 240, 236, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(123, 111, 160, 0.12);
    border-radius: 12px;
    padding: 6px;
    box-shadow: 0 8px 24px rgba(26, 31, 58, 0.08), 0 16px 48px rgba(26, 31, 58, 0.06);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s ease;
    z-index: 50;
  }
  .lang-switcher.open .lang-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 8px;
    font-family: var(--font-nav);
    font-size: 14px;
    color: var(--color-text-body);
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .lang-option:hover {
    background: rgba(123, 111, 160, 0.07);
    text-decoration: none;
    color: var(--color-text-heading);
  }
  .lang-option-current {
    color: var(--color-text-heading);
    font-weight: 600;
  }
  .lang-check {
    margin-left: auto;
    color: var(--color-primary);
  }

  /* CTA button */
  .header-cta {
    display: inline-flex;
    align-items: center;
    background: var(--color-text-heading);
    border-radius: var(--border-radius-pill);
    color: var(--color-bg-cream);
    font-family: var(--font-nav);
    font-weight: 600;
    padding: 8px 22px;
    font-size: 13px;
    letter-spacing: 0.3px;
    transition: all 0.25s ease;
    border: none;
  }
  .header-cta:hover {
    background: var(--color-primary);
    color: var(--color-bg-cream);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(123, 111, 160, 0.25);
    text-decoration: none;
  }

  /* Hamburger */
  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-heading);
    padding: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  @media (min-width: 768px) {
    .hamburger-btn {
      display: none;
    }
  }
  .hamburger-btn:hover {
    background: rgba(123, 111, 160, 0.07);
  }
</style>

<!-- Global styles for mobile menu -->
<style is:global>
  .mobile-menu-panel {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: linear-gradient(180deg, #1a1f3a 0%, #0f1328 100%);
    overflow: hidden;
  }

  .mobile-menu-hidden {
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu-visible {
    transform: translateX(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 64px;
  }

  .mobile-close {
    color: rgba(242, 237, 230, 0.5);
    padding: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .mobile-close:hover {
    color: #f2ede6;
    background: rgba(255, 255, 255, 0.08);
  }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    padding: 40px 24px;
    gap: 4px;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 400;
    color: #f2ede6;
    text-decoration: none;
    padding: 14px 16px;
    border-radius: 12px;
    transition: all 0.2s ease;
  }
  .mobile-nav-link:hover {
    color: var(--color-accent);
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .mobile-nav-link-small {
    font-family: var(--font-nav);
    font-size: 16px;
    font-weight: 400;
    color: rgba(242, 237, 230, 0.45);
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 16px 16px;
  }

  .mobile-lang-row {
    display: flex;
    gap: 10px;
    padding: 0 16px;
    flex-wrap: wrap;
  }

  .mobile-lang-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: var(--border-radius-pill);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(242, 237, 230, 0.7);
    font-family: var(--font-nav);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .mobile-lang-chip:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #f2ede6;
    text-decoration: none;
  }
  .mobile-lang-chip-current {
    background: rgba(29, 158, 117, 0.12);
    border-color: rgba(29, 158, 117, 0.3);
    color: #f2ede6;
  }

  .mobile-menu-orb {
    position: absolute;
    bottom: -80px;
    right: -60px;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(123, 111, 160, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-close-btn');

  function openMenu() {
    mobileMenu?.classList.remove('mobile-menu-hidden');
    mobileMenu?.classList.add('mobile-menu-visible');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.remove('mobile-menu-visible');
    mobileMenu?.classList.add('mobile-menu-hidden');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  mobileMenu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.mobile-menu-links, .mobile-menu-top')) return;
    closeMenu();
  });

  // Language switcher dropdown
  const langSwitcher = document.getElementById('lang-switcher');
  const langBtn = langSwitcher?.querySelector('.lang-btn');

  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = langSwitcher?.classList.toggle('open');
    langBtn.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (langSwitcher && !langSwitcher.contains(e.target as Node)) {
      langSwitcher.classList.remove('open');
      langBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      langSwitcher?.classList.remove('open');
      langBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
