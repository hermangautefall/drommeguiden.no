---
import { defaultLang, type Lang } from '../i18n/config';
import { pathFor } from '../i18n/utils';

interface Props {
  relaterte: string[];
  lang?: Lang;
}

const { relaterte, lang = defaultLang } = Astro.props;
const label = lang === 'sv' ? 'Utforska vidare' : 'Utforsk videre';
const title = lang === 'sv' ? 'Relaterade drömsymboler' : 'Relaterte drømmesymboler';
---

{relaterte.length > 0 && (
  <div class="relaterte-section">
    <span class="relaterte-label">{label}</span>
    <h2 class="relaterte-title">{title}</h2>
    <div class="relaterte-grid">
      {relaterte.map((slug) => (
        <a href={pathFor(lang, 'drommer', slug)} class="relaterte-chip">
          {slug.replace(/-/g, ' ')}
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .relaterte-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid rgba(123, 111, 160, 0.1);
  }

  .relaterte-label {
    display: block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .relaterte-title {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--color-text-heading);
    margin-bottom: 24px;
    font-weight: 400;
  }

  .relaterte-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .relaterte-chip {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(123, 111, 160, 0.12);
    color: var(--color-text-body);
    padding: 10px 20px;
    border-radius: var(--border-radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    text-transform: capitalize;
    transition: all 0.25s ease;
  }
  .relaterte-chip:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(123, 111, 160, 0.25);
  }
</style>
