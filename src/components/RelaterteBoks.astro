---
interface Props {
  relaterte: string[];
}

const { relaterte } = Astro.props;
---

{relaterte.length > 0 && (
  <div class="relaterte-section">
    <h2 class="relaterte-title">Relaterte drømmesymboler</h2>
    <div class="relaterte-grid">
      {relaterte.map((slug) => (
        <a href={`/drommer/${slug}`} class="relaterte-chip">
          <span class="relaterte-chip-dot"></span>
          {slug.replace(/-/g, ' ')}
          <span class="relaterte-chip-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .relaterte-section {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid rgba(123, 111, 160, 0.15);
  }

  .relaterte-title {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--color-text-heading);
    margin-bottom: 24px;
    font-weight: 700;
  }

  .relaterte-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .relaterte-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-bg-white);
    border: 1px solid rgba(123, 111, 160, 0.15);
    color: var(--color-text-body);
    padding: 10px 18px;
    border-radius: var(--border-radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    text-transform: capitalize;
    transition: var(--transition);
    box-shadow: 0 2px 8px rgba(26, 31, 58, 0.04);
  }
  .relaterte-chip:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--box-shadow-card);
  }

  .relaterte-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    transition: background 0.2s ease;
  }
  .relaterte-chip:hover .relaterte-chip-dot {
    background: white;
  }

  .relaterte-chip-arrow {
    font-size: 13px;
    opacity: 0;
    transition: var(--transition);
    margin-left: -4px;
  }
  .relaterte-chip:hover .relaterte-chip-arrow {
    opacity: 1;
    margin-left: 0;
  }
</style>
