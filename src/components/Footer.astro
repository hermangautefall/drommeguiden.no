---
import { languages, defaultLang, type Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { pathFor, homePath } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const langConfig = languages[lang];

// Popular symbol slugs per language
const popularSlugs = lang === 'sv'
  ? [
      { slug: 'orm', label: 'Orm' },
      { slug: 'hav', label: 'Hav' },
      { slug: 'ex', label: 'Ex' },
      { slug: 'flyga', label: 'Flyga' },
    ]
  : [
      { slug: 'slange', label: 'Slange' },
      { slug: 'hav', label: 'Hav' },
      { slug: 'eksen', label: 'Eksen' },
      { slug: 'flyging', label: 'Flyging' },
    ];

const drommerBase = pathFor(lang, 'drommer');
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Top section: brand + nav -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href={homePath(lang)} class="footer-logo">
          <span class="footer-moon" aria-hidden="true">🌙</span> {langConfig.brand}
        </a>
        <p class="footer-tagline">
          {t('footer.tagline')}
        </p>
      </div>

      <!-- Navigation columns -->
      <div class="footer-columns">
        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.utforsk')}</h3>
          <ul class="footer-links">
            <li><a href={pathFor(lang, 'drommer')}>{t('sitemap.alle')}</a></li>
            <li><a href={pathFor(lang, 'kategori')}>{t('nav.kategorier')}</a></li>
            <li><a href={pathFor(lang, 'guider')}>{t('nav.guider')}</a></li>
            <li><a href={pathFor(lang, 'sovn')}>{t('nav.sovn')}</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.populart')}</h3>
          <ul class="footer-links">
            {popularSlugs.map(p => (
              <li><a href={`${drommerBase}${p.slug}/`}>{p.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.info')}</h3>
          <ul class="footer-links">
            <li><a href={pathFor(lang, 'omOss')}>{t('nav.omOss')}</a></li>
            <li><a href={pathFor(lang, 'kontakt')}>{t('nav.kontakt')}</a></li>
            <li><a href={pathFor(lang, 'personvern')}>{t('nav.personvern')}</a></li>
            <li><a href={pathFor(lang, 'cookies')}>Cookies</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {langConfig.brand}</p>
      <p class="footer-credit">Bilder fra <a href="https://www.pexels.com" target="_blank" rel="noopener">Pexels</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #1a1f3a 0%, #0f1328 100%);
  }

  .footer-inner {
    position: relative;
    z-index: 2;
    max-width: 1000px;
    margin: 0 auto;
    padding: 56px 20px 32px;
  }
  @media (min-width: 768px) {
    .footer-inner {
      padding: 80px 48px 40px;
    }
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 64px;
    }
  }

  /* Brand */
  .footer-brand {
    max-width: 320px;
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    color: #f2ede6;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .footer-logo:hover {
    text-decoration: none;
    color: #f2ede6;
  }
  .footer-moon {
    font-size: 22px;
  }

  .footer-tagline {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.4);
  }

  /* Columns */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
    }
  }

  .footer-col-title {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.3);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    font-size: 14px;
    color: rgba(242, 237, 230, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-links a:hover {
    color: #f2ede6;
    text-decoration: none;
  }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 48px 0 24px;
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: rgba(242, 237, 230, 0.25);
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-credit a {
    color: rgba(242, 237, 230, 0.35);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-credit a:hover {
    color: #f2ede6;
    text-decoration: none;
  }
</style>
