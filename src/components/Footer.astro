---
// Simplified footer — clean, airy, fewer columns
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Top section: brand + nav -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-moon" aria-hidden="true">🌙</span> Drømmeguiden
        </a>
        <p class="footer-tagline">
          Norges mest komplette guide til drømmesymboler og drømmetolkning.
        </p>
      </div>

      <!-- Navigation columns -->
      <div class="footer-columns">
        <div class="footer-col">
          <h3 class="footer-col-title">Utforsk</h3>
          <ul class="footer-links">
            <li><a href="/drommer/">Alle symboler</a></li>
            <li><a href="/kategori/">Kategorier</a></li>
            <li><a href="/guider/">Guider</a></li>
            <li><a href="/sovn/">Søvn</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">Populært</h3>
          <ul class="footer-links">
            <li><a href="/drommer/slange/">Slange</a></li>
            <li><a href="/drommer/hav/">Hav</a></li>
            <li><a href="/drommer/eksen/">Eksen</a></li>
            <li><a href="/drommer/flyging/">Flyging</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">Info</h3>
          <ul class="footer-links">
            <li><a href="/om-oss/">Om oss</a></li>
            <li><a href="/kontakt/">Kontakt</a></li>
            <li><a href="/personvern/">Personvern</a></li>
            <li><a href="/cookies/">Cookies</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Drømmeguiden</p>
      <p class="footer-credit">Bilder fra <a href="https://www.pexels.com" target="_blank" rel="noopener">Pexels</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #1a1f3a 0%, #0f1328 100%);
  }

  .footer-inner {
    position: relative;
    z-index: 2;
    max-width: 1000px;
    margin: 0 auto;
    padding: 64px 24px 32px;
  }
  @media (min-width: 768px) {
    .footer-inner {
      padding: 80px 48px 40px;
    }
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 64px;
    }
  }

  /* Brand */
  .footer-brand {
    max-width: 320px;
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    color: #f2ede6;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .footer-logo:hover {
    text-decoration: none;
    color: #f2ede6;
  }
  .footer-moon {
    font-size: 22px;
  }

  .footer-tagline {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.4);
  }

  /* Columns */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
    }
  }

  .footer-col-title {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.3);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    font-size: 14px;
    color: rgba(242, 237, 230, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-links a:hover {
    color: #f2ede6;
    text-decoration: none;
  }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 48px 0 24px;
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: rgba(242, 237, 230, 0.25);
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-credit a {
    color: rgba(242, 237, 230, 0.35);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-credit a:hover {
    color: #f2ede6;
    text-decoration: none;
  }
</style>
