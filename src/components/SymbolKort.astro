---
import { defaultLang, type Lang } from '../i18n/config';
import { pathFor } from '../i18n/utils';

interface Props {
  tittel: string;
  slug: string;
  kortbeskrivelse: string;
  kategori: string;
  bilde?: string;
  lang?: Lang;
}

const { tittel, slug, kortbeskrivelse, kategori, bilde, lang = defaultLang } = Astro.props;
---

<a href={pathFor(lang, 'drommer', slug)} class="symbolkort">
  {bilde && (
    <div class="symbolkort-img-wrap">
      <img src={bilde} alt={tittel} class="symbolkort-img" loading="lazy" />
    </div>
  )}
  <div class="symbolkort-body">
    <span class="symbolkort-kat">{kategori}</span>
    <h3 class="symbolkort-title">
      {tittel.replace(/ — hva betyr det\?/, '').replace(/ — vad betyder det\?/, '')}
    </h3>
    <p class="symbolkort-desc">{kortbeskrivelse}</p>
  </div>
</a>

<style>
  .symbolkort {
    display: block;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(123, 111, 160, 0.08);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .symbolkort:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(26, 31, 58, 0.08), 0 24px 48px rgba(26, 31, 58, 0.06);
    text-decoration: none;
    border-color: rgba(123, 111, 160, 0.15);
  }

  .symbolkort-img-wrap {
    overflow: hidden;
  }

  .symbolkort-img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .symbolkort:hover .symbolkort-img {
    transform: scale(1.03);
  }

  .symbolkort-body {
    padding: 20px 22px;
  }

  .symbolkort-kat {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .symbolkort-title {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-text-heading);
    margin-bottom: 8px;
    font-weight: 400;
    line-height: 1.3;
  }

  .symbolkort-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
