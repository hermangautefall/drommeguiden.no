---
interface Props {
  tittel: string;
  slug: string;
  kortbeskrivelse: string;
  kategori: string;
  bilde?: string;
}

const { tittel, slug, kortbeskrivelse, kategori, bilde } = Astro.props;
---

<a href={`/drommer/${slug}`} class="symbolkort">
  {bilde && (
    <img src={bilde} alt={tittel} class="symbolkort-img" loading="lazy" />
  )}
  <div class="symbolkort-body">
    <span class="symbolkort-kat">{kategori}</span>
    <h3 class="symbolkort-title">
      {tittel.replace(/ — hva betyr det\?/, '')}
    </h3>
    <p class="symbolkort-desc">{kortbeskrivelse}</p>
  </div>
</a>

<style>
  .symbolkort {
    display: block;
    background: var(--color-bg-white);
    border-radius: var(--border-radius-card);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--box-shadow-card);
    transition: var(--transition);
  }
  .symbolkort:hover {
    transform: translateY(-4px);
    box-shadow: var(--box-shadow-hover);
    text-decoration: none;
  }

  .symbolkort-img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .symbolkort-body {
    padding: 20px;
  }

  .symbolkort-kat {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .symbolkort-title {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-text-heading);
    margin-bottom: 8px;
    font-weight: 700;
    line-height: 1.3;
  }

  .symbolkort-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
