---
// Giscus comment system component
---

<section class="kommentarer-section">
  <span class="kommentarer-label">Delta i samtalen</span>
  <h2 class="kommentarer-title">Kommentarer</h2>
  <p class="kommentarer-desc">
    Har du drømt noe lignende? Del din opplevelse eller still et spørsmål.
  </p>
  <div class="giscus-wrapper">
    <script
      src="https://giscus.app/client.js"
      data-repo="hermangautefall/drommeguiden.no"
      data-repo-id="R_kgDORpoPww"
      data-category="Announcements"
      data-category-id="DIC_kwDORpoPw84C4uXs"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="nb"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

<style>
  .kommentarer-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid rgba(123, 111, 160, 0.1);
  }

  .kommentarer-label {
    display: block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .kommentarer-title {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--color-text-heading);
    font-weight: 400;
    margin: 0 0 8px 0;
  }

  .kommentarer-desc {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .giscus-wrapper {
    min-height: 200px;
  }
</style>
