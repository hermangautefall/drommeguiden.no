---
// SVG wave underline decoration — use under headings for a soft, organic feel
interface Props {
  width?: string;
  color?: string;
}

const { width = '120px', color = 'var(--color-primary)' } = Astro.props;
---

<div class="bolge-wrapper" style={`width: ${width};`}>
  <svg
    viewBox="0 0 120 8"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="bolge-svg"
    preserveAspectRatio="none"
  >
    <path
      d="M0 4C10 1 20 7 30 4C40 1 50 7 60 4C70 1 80 7 90 4C100 1 110 7 120 4"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      fill="none"
      opacity="0.6"
    />
  </svg>
</div>

<style>
  .bolge-wrapper {
    margin: 8px 0 0;
    line-height: 0;
  }
  .bolge-svg {
    width: 100%;
    height: 8px;
  }
</style>
