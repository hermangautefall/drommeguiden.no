---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  tittel: string;
  beskrivelse: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { tittel, beskrivelse, canonicalUrl, ogImage = '/og-image.png' } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tittel} | Drømmeguiden</title>
    <meta name="description" content={beskrivelse} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${tittel} | Drømmeguiden`} />
    <meta property="og:description" content={beskrivelse} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nb_NO" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles -->
    <style>
      @import '../styles/global.css';
    </style>

    <!-- Ezoic head script placeholder -->
    <!-- <script async src="//www.ezojs.com/ezoic/sa.min.js"></script> -->

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-pattern" style="background-color: var(--color-bg-cream); color: var(--color-text-body);">
    <Header />

    <main class="flex-1 max-w-5xl mx-auto px-4 py-10 w-full">
      <slot />
    </main>

    <Footer />
  </body>
</html>
