---
import Base from './Base.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';
import { defaultLang, type Lang } from '../i18n/config';
import { pathFor, homePath } from '../i18n/utils';

interface AlternateLink {
  lang: Lang;
  url: string;
}

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  slug: string;
  leseminutter?: number;
  dato: Date;
  bilde?: string;
  lang?: Lang;
  alternates?: AlternateLink[];
}

const { tittel, kortbeskrivelse, slug, leseminutter, dato, bilde, lang = defaultLang, alternates = [] } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;

const labels = lang === 'sv'
  ? { hjem: 'Hem', guider: 'Guider', breadcrumb: 'Brödsmulor', lesetid: 'min läsning', innhold: 'Innehåll' }
  : { hjem: 'Hjem', guider: 'Guider', breadcrumb: 'Brødsmuler', lesetid: 'min lesetid', innhold: 'Innhold' };

const canonical = `https://drommeguiden.no${pathFor(lang, 'guider', slug)}`;
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={canonical} lang={lang} alternates={alternates}>
  <article class="guide-article">
    <!-- Breadcrumb -->
    <nav class="guide-breadcrumb" aria-label={labels.breadcrumb}>
      <a href={homePath(lang)}>{labels.hjem}</a>
      <span class="guide-sep" aria-hidden="true">/</span>
      <a href={pathFor(lang, 'guider')}>{labels.guider}</a>
      <span class="guide-sep" aria-hidden="true">/</span>
      <span class="guide-current">{tittel}</span>
    </nav>

    <!-- Header -->
    <header class="guide-header">
      {leseminutter && (
        <span class="guide-meta">{leseminutter} {labels.lesetid}</span>
      )}
      <h1 class="guide-title">{tittel}</h1>
      <p class="guide-intro">{kortbeskrivelse}</p>
    </header>

    {bilde && (
      <div class="guide-image-wrapper">
        <img src={bilde} alt={tittel} class="guide-image" loading="eager" />
        {bildeFilnavn && <BildeKreditt filnavn={bildeFilnavn} />}
      </div>
    )}

    <!-- 2-column: TOC sidebar + content -->
    <div class="guide-layout">
      <aside class="guide-toc" id="guide-toc">
        <p class="toc-label">{labels.innhold}</p>
        <nav id="toc-nav" aria-label={labels.innhold}>
          <!-- Populated by client-side JS -->
        </nav>
      </aside>

      <div class="guide-content prose" id="guide-content">
        <slot />
        <Kommentarer />
      </div>
    </div>
  </article>

  <!-- Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: tittel,
      description: kortbeskrivelse,
      datePublished: dato.toISOString(),
      url: `https://drommeguiden.no/guider/${slug}`,
      ...(bilde && { image: `https://drommeguiden.no${bilde}` }),
      publisher: {
        '@type': 'Organization',
        name: 'Drømmeguiden',
        url: 'https://drommeguiden.no',
      },
    })}
  />

  <!-- Auto-generate TOC from h2 headings -->
  <script>
    const content = document.getElementById('guide-content');
    const tocNav = document.getElementById('toc-nav');
    if (content && tocNav) {
      const headings = content.querySelectorAll('h2');
      if (headings.length > 0) {
        const list = document.createElement('ul');
        list.className = 'toc-list';
        headings.forEach((h, i) => {
          const id = h.id || `section-${i}`;
          h.id = id;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = h.textContent || '';
          a.className = 'toc-link';
          li.appendChild(a);
          list.appendChild(li);
        });
        tocNav.appendChild(list);

        const links = tocNav.querySelectorAll('.toc-link');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('toc-active'));
              const activeLink = tocNav.querySelector(`a[href="#${entry.target.id}"]`);
              if (activeLink) activeLink.classList.add('toc-active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        headings.forEach(h => observer.observe(h));
      } else {
        const toc = document.getElementById('guide-toc');
        if (toc) toc.style.display = 'none';
      }
    }
  </script>
</Base>

<style>
  .guide-article {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .guide-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 32px;
    padding-top: 8px;
  }
  .guide-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .guide-breadcrumb a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .guide-sep { color: var(--color-text-muted); opacity: 0.35; font-size: 11px; }
  .guide-current { color: var(--color-text-body); }

  /* Header */
  .guide-header {
    margin-bottom: 36px;
  }
  .guide-meta {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
    margin-bottom: 14px;
  }
  .guide-title {
    font-family: var(--font-heading);
    font-size: 30px;
    line-height: 1.15;
    color: var(--color-text-heading);
    margin-bottom: 16px;
    font-weight: 400;
    word-wrap: break-word;
    hyphens: auto;
  }
  @media (min-width: 480px) {
    .guide-title { font-size: 40px; }
  }
  @media (min-width: 768px) {
    .guide-title { font-size: 48px; }
  }
  .guide-intro {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  /* Image */
  .guide-image-wrapper {
    margin-bottom: 40px;
  }
  .guide-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 16px;
  }

  /* 2-column layout */
  .guide-layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .guide-layout {
      flex-direction: row;
      gap: 48px;
    }
  }

  /* TOC sidebar */
  .guide-toc {
    display: none;
  }
  @media (min-width: 768px) {
    .guide-toc {
      display: block;
      width: 200px;
      flex-shrink: 0;
      position: sticky;
      top: 100px;
      align-self: flex-start;
      max-height: calc(100vh - 140px);
      overflow-y: auto;
    }
  }

  .toc-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    font-weight: 600;
  }

  :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid rgba(123, 111, 160, 0.12);
  }

  :global(.toc-link) {
    display: block;
    padding: 6px 0 6px 16px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }
  :global(.toc-link:hover) {
    color: var(--color-primary);
    text-decoration: none;
  }
  :global(.toc-link.toc-active) {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    font-weight: 600;
  }

  .guide-content {
    flex: 1;
    min-width: 0;
  }
</style>
