---
import Base from './Base.astro';
import SymbolKort from '../components/SymbolKort.astro';
import { getCollection } from 'astro:content';

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  slug: string;
}

const { tittel, kortbeskrivelse, slug } = Astro.props;

const alleSymboler = await getCollection('drommer');
const symbolerIKategori = alleSymboler.filter((s) => s.data.kategori === slug);

const emojiMap: Record<string, string> = {
  dyr: '🐾', vann: '🌊', kropp: '🫀', steder: '🏠',
  hendelser: '⚡', mennesker: '👤', natur: '🌿', gjenstander: '🔑',
};
const emoji = emojiMap[slug] || '✨';
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={`https://drommeguiden.no/kategori/${slug}/`}>
  <!-- Category Hero -->
  <div class="kategori-hero">
    <nav class="kategori-breadcrumb" aria-label="Brødsmuler">
      <a href="/">Hjem</a>
      <span>›</span>
      <a href="/kategori">Kategorier</a>
      <span>›</span>
      <span class="current">{tittel.replace('Drømmesymboler: ', '')}</span>
    </nav>
    <span class="kategori-emoji">{emoji}</span>
    <h1 class="kategori-title">{tittel}</h1>
    <p class="kategori-desc">{kortbeskrivelse}</p>
    <p class="kategori-count">{symbolerIKategori.length} drømmesymboler i denne kategorien</p>
  </div>

  <article class="kategori-article">
    <div class="prose kategori-prose">
      <slot />
    </div>

    {symbolerIKategori.length > 0 && (
      <section class="kategori-symbols">
        <h2 class="kategori-symbols-title">Utforsk symbolene</h2>
        <div class="kategori-grid">
          {symbolerIKategori.map((d) => (
            <SymbolKort
              tittel={d.data.tittel}
              slug={d.data.slug}
              kortbeskrivelse={d.data.kortbeskrivelse}
              kategori={d.data.kategori}
              bilde={d.data.bilde}
            />
          ))}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .kategori-hero {
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, #2d3566 60%, #3a4070 100%);
    margin: -2rem -1rem 0;
    padding: 48px 24px 56px;
    text-align: center;
  }
  @media (min-width: 768px) {
    .kategori-hero {
      margin: -2rem calc(-50vw + 50%) 0;
      padding: 64px 48px 72px;
    }
  }

  .kategori-breadcrumb {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 24px;
    color: rgba(242, 237, 230, 0.5);
  }
  .kategori-breadcrumb a {
    color: rgba(242, 237, 230, 0.5);
    text-decoration: none;
  }
  .kategori-breadcrumb a:hover {
    color: rgba(242, 237, 230, 0.8);
    text-decoration: none;
  }
  .kategori-breadcrumb .current {
    color: rgba(242, 237, 230, 0.8);
    font-weight: 600;
  }

  .kategori-emoji {
    display: block;
    font-size: 56px;
    margin-bottom: 16px;
  }

  .kategori-title {
    font-family: var(--font-heading);
    font-size: 40px;
    color: #f2ede6;
    margin-bottom: 12px;
    font-weight: 700;
  }
  @media (min-width: 768px) {
    .kategori-title {
      font-size: 48px;
    }
  }

  .kategori-desc {
    font-size: 16px;
    color: rgba(242, 237, 230, 0.7);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 16px;
  }

  .kategori-count {
    font-family: var(--font-nav);
    font-size: 13px;
    color: var(--color-accent);
    letter-spacing: 0.5px;
  }

  .kategori-article {
    max-width: 960px;
    margin: 0 auto;
    padding-top: 48px;
  }

  .kategori-prose {
    margin-bottom: 48px;
  }

  .kategori-symbols {
    margin-bottom: 48px;
  }

  .kategori-symbols-title {
    font-family: var(--font-heading);
    font-size: 32px;
    color: var(--color-text-heading);
    margin-bottom: 28px;
    font-weight: 700;
  }

  .kategori-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 480px) {
    .kategori-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 768px) {
    .kategori-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
