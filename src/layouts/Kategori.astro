---
import Base from './Base.astro';
import SymbolKort from '../components/SymbolKort.astro';
import { getCollection } from 'astro:content';

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  slug: string;
  lang?: 'nb' | 'sv';
  alternates?: { lang: string; url: string }[];
}

const { tittel, kortbeskrivelse, slug, lang = 'nb', alternates = [] } = Astro.props;

const collectionName = lang === 'sv' ? 'drommer-sv' : 'drommer';
const alleSymboler = await getCollection(collectionName);
const symbolerIKategori = alleSymboler.filter((s) => s.data.kategori === slug);

const emojiMap: Record<string, string> = lang === 'sv'
  ? {
      djur: '🐾', vatten: '🌊', kropp: '🫀', platser: '🏠',
      handelser: '⚡', manniskor: '👤', natur: '🌿', foremal: '🔑', andlig: '✨',
    }
  : {
      dyr: '🐾', vann: '🌊', kropp: '🫀', steder: '🏠',
      hendelser: '⚡', mennesker: '👤', natur: '🌿', gjenstander: '🔑',
    };
const emoji = emojiMap[slug] || '✨';
const displayTitle = tittel.replace('Drømmesymboler: ', '').replace('Drömsymboler: ', '');

const labels = lang === 'sv'
  ? {
      home: 'Hem',
      categories: 'Kategorier',
      breadcrumb: 'Brödsmulor',
      countSuffix: 'drömsymboler',
      allLabel: 'Alla symboler',
      allTitle: 'Utforska symbolerna',
    }
  : {
      home: 'Hjem',
      categories: 'Kategorier',
      breadcrumb: 'Brødsmuler',
      countSuffix: 'drømmesymboler',
      allLabel: 'Alle symboler',
      allTitle: 'Utforsk symbolene',
    };

const canonicalUrl = lang === 'sv'
  ? `https://drommeguiden.no/sv/kategori/${slug}/`
  : `https://drommeguiden.no/kategori/${slug}/`;

const homeHref = lang === 'sv' ? '/sv/' : '/';
const categoriesHref = lang === 'sv' ? '/sv/kategori/' : '/kategori/';
---

<Base
  tittel={tittel}
  beskrivelse={kortbeskrivelse}
  canonicalUrl={canonicalUrl}
  lang={lang}
  alternates={alternates}
>
  <div class="kategori-page">
    <!-- Hero -->
    <div class="kategori-hero">
      <nav class="kategori-breadcrumb" aria-label={labels.breadcrumb}>
        <a href={homeHref}>{labels.home}</a>
        <span aria-hidden="true">/</span>
        <a href={categoriesHref}>{labels.categories}</a>
        <span aria-hidden="true">/</span>
        <span class="current">{displayTitle}</span>
      </nav>
      <span class="kategori-emoji" aria-hidden="true">{emoji}</span>
      <h1 class="kategori-title">{tittel}</h1>
      <p class="kategori-desc">{kortbeskrivelse}</p>
      <p class="kategori-count">{symbolerIKategori.length} {labels.countSuffix}</p>
    </div>

    <!-- Wave transition -->
    <div class="kategori-wave" aria-hidden="true">
      <svg viewBox="0 0 1200 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 60 C200 20 400 40 600 25 C800 10 1000 35 1200 15 L1200 0 L0 0Z" fill="var(--color-bg-cream)" opacity="0.5"/>
        <path d="M0 60 C150 35 350 50 550 30 C750 10 950 45 1200 20 L1200 0 L0 0Z" fill="var(--color-bg-cream)"/>
      </svg>
    </div>

    <article class="kategori-article">
      <div class="prose kategori-prose">
        <slot />
      </div>

      {symbolerIKategori.length > 0 && (
        <section class="kategori-symbols">
          <span class="kategori-symbols-label">{labels.allLabel}</span>
          <h2 class="kategori-symbols-title">{labels.allTitle}</h2>
          <div class="kategori-grid">
            {symbolerIKategori.map((d) => (
              <SymbolKort
                tittel={d.data.tittel}
                slug={d.data.slug}
                kortbeskrivelse={d.data.kortbeskrivelse}
                kategori={d.data.kategori}
                bilde={d.data.bilde}
                lang={lang}
              />
            ))}
          </div>
        </section>
      )}
    </article>
  </div>
</Base>

<style>
  .kategori-page {
    margin: -40px -16px 0;
  }
  @media (min-width: 768px) {
    .kategori-page {
      margin: -40px -24px 0;
    }
  }

  .kategori-hero {
    background: linear-gradient(160deg, #0f1328 0%, #1a2340 40%, #0f2030 100%);
    padding: 56px 20px 64px;
    text-align: center;
  }
  @media (min-width: 768px) {
    .kategori-hero {
      padding: 72px 48px 80px;
    }
  }

  .kategori-breadcrumb {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 28px;
    color: rgba(242, 237, 230, 0.35);
  }
  .kategori-breadcrumb a {
    color: rgba(242, 237, 230, 0.45);
    text-decoration: none;
  }
  .kategori-breadcrumb a:hover {
    color: rgba(242, 237, 230, 0.8);
    text-decoration: none;
  }
  .kategori-breadcrumb .current {
    color: rgba(242, 237, 230, 0.7);
  }

  .kategori-emoji {
    display: block;
    font-size: 48px;
    margin-bottom: 16px;
  }

  .kategori-title {
    font-family: var(--font-heading);
    font-size: 30px;
    color: #f2ede6;
    margin-bottom: 14px;
    font-weight: 400;
    word-wrap: break-word;
    hyphens: auto;
  }
  @media (min-width: 480px) {
    .kategori-title {
      font-size: 40px;
    }
  }
  @media (min-width: 768px) {
    .kategori-title {
      font-size: 52px;
    }
  }

  .kategori-desc {
    font-size: 16px;
    color: rgba(242, 237, 230, 0.65);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto 16px;
  }

  .kategori-count {
    font-family: var(--font-nav);
    font-size: 13px;
    color: rgba(242, 237, 230, 0.35);
    letter-spacing: 0.5px;
  }

  /* Wave transition */
  .kategori-wave {
    margin-top: -30px;
    position: relative;
    z-index: 3;
  }
  .kategori-wave svg {
    display: block;
    width: 100%;
    height: 40px;
  }

  .kategori-article {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 20px 0;
  }
  @media (min-width: 768px) {
    .kategori-article {
      padding: 48px 24px 0;
    }
  }

  .kategori-prose {
    margin-bottom: 56px;
  }

  .kategori-symbols {
    margin-bottom: 48px;
  }

  .kategori-symbols-label {
    display: block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .kategori-symbols-title {
    font-family: var(--font-heading);
    font-size: 26px;
    color: var(--color-text-heading);
    margin-bottom: 28px;
    font-weight: 400;
  }
  @media (min-width: 480px) {
    .kategori-symbols-title { font-size: 32px; }
  }

  .kategori-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 480px) {
    .kategori-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 768px) {
    .kategori-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
