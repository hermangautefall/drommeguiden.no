---
import Base from './Base.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';
import { getCollection } from 'astro:content';

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  slug: string;
  kategori: string;
  leseminutter: number;
  dato: Date;
  oppdatert?: Date;
  bilde?: string;
  relaterte_sovn?: string[];
  relaterte_drommer?: string[];
}

const { tittel, kortbeskrivelse, slug, kategori, leseminutter, dato, oppdatert, bilde, relaterte_sovn, relaterte_drommer } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;

// Category colors and labels
const kategoriMap: Record<string, { label: string; color: string; bg: string; border: string }> = {
  vitenskap: { label: 'Søvnvitenskap', color: '#7B6FA0', bg: 'rgba(123, 111, 160, 0.12)', border: 'rgba(123, 111, 160, 0.3)' },
  hygiene: { label: 'Søvnhygiene', color: '#1D9E75', bg: 'rgba(29, 158, 117, 0.12)', border: 'rgba(29, 158, 117, 0.3)' },
  lidelser: { label: 'Søvnlidelser', color: '#C07050', bg: 'rgba(192, 112, 80, 0.12)', border: 'rgba(192, 112, 80, 0.3)' },
  livsfaser: { label: 'Livsfaser', color: '#4A8BBF', bg: 'rgba(74, 139, 191, 0.12)', border: 'rgba(74, 139, 191, 0.3)' },
  produkter: { label: 'Produkter', color: '#B8960C', bg: 'rgba(184, 150, 12, 0.12)', border: 'rgba(184, 150, 12, 0.3)' },
  psykologi: { label: 'Søvnpsykologi', color: '#9B7FBF', bg: 'rgba(155, 127, 191, 0.12)', border: 'rgba(155, 127, 191, 0.3)' },
};
const kat = kategoriMap[kategori] || kategoriMap.vitenskap;

// Fetch related sovn articles
const alleSovn = await getCollection('sovn');
const relaterteSovnArtikler = (relaterte_sovn || [])
  .map(slug => alleSovn.find(a => a.data.slug === slug))
  .filter(Boolean);

// Fetch related dream guides
const alleGuider = await getCollection('guider');
const relaterteDrommerArtikler = (relaterte_drommer || [])
  .map(slug => alleGuider.find(g => g.data.slug === slug))
  .filter(Boolean);
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={`https://drommeguiden.no/sovn/${slug}/`}>
  <article class="sovn-article">
    <!-- Breadcrumb -->
    <nav class="sovn-breadcrumb" aria-label="Brødsmuler">
      <a href="/">Hjem</a>
      <span class="sovn-sep">›</span>
      <a href="/sovn">Søvn</a>
      <span class="sovn-sep">›</span>
      <span class="sovn-current">{tittel}</span>
    </nav>

    <!-- Header -->
    <header class="sovn-header">
      <span class="sovn-badge" style={`color: ${kat.color}; background: ${kat.bg}; border-color: ${kat.border};`}>
        {kat.label}
      </span>
      <div class="sovn-meta-row">
        <span class="sovn-meta">📖 {leseminutter} min lesetid</span>
        {oppdatert && (
          <span class="sovn-meta">Oppdatert {oppdatert.toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        )}
      </div>
      <h1 class="sovn-title">{tittel}</h1>
      <p class="sovn-intro">{kortbeskrivelse}</p>
    </header>

    {bilde && (
      <div class="sovn-image-wrapper">
        <img src={bilde} alt={tittel} class="sovn-image" loading="eager" />
        {bildeFilnavn && <BildeKreditt filnavn={bildeFilnavn} />}
      </div>
    )}

    <!-- 2-column: TOC sidebar + content -->
    <div class="sovn-layout">
      <aside class="sovn-toc" id="sovn-toc">
        <p class="toc-label">Innhold</p>
        <nav id="toc-nav" aria-label="Innholdsfortegnelse"></nav>
      </aside>

      <div class="sovn-content prose" id="sovn-content">
        <slot />

        <!-- Related sovn articles -->
        {relaterteSovnArtikler.length > 0 && (
          <div class="sovn-related">
            <h3 class="sovn-related-title">Les mer om søvn</h3>
            <div class="sovn-related-grid">
              {relaterteSovnArtikler.map((art: any) => {
                const artKat = kategoriMap[art.data.kategori] || kategoriMap.vitenskap;
                return (
                  <a href={`/sovn/${art.data.slug}`} class="sovn-related-card">
                    <span class="sovn-related-badge" style={`color: ${artKat.color};`}>{artKat.label}</span>
                    <span class="sovn-related-name">{art.data.tittel}</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Related dream content -->
        {relaterteDrommerArtikler.length > 0 && (
          <div class="sovn-related sovn-related-drommer">
            <h3 class="sovn-related-title">Fra drømmeguiden</h3>
            <div class="sovn-related-grid">
              {relaterteDrommerArtikler.map((art: any) => (
                <a href={`/guider/${art.data.slug}`} class="sovn-related-card sovn-related-card-dream">
                  <span class="sovn-related-badge" style="color: var(--color-accent);">Guide</span>
                  <span class="sovn-related-name">{art.data.tittel}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Comments -->
        <Kommentarer />
      </div>
    </div>
  </article>

  <!-- Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: tittel,
      description: kortbeskrivelse,
      datePublished: dato.toISOString(),
      ...(oppdatert && { dateModified: oppdatert.toISOString() }),
      url: `https://drommeguiden.no/sovn/${slug}`,
      ...(bilde && { image: `https://drommeguiden.no${bilde}` }),
      publisher: {
        '@type': 'Organization',
        name: 'Drømmeguiden',
        url: 'https://drommeguiden.no',
      },
    })}
  />

  <!-- Auto-generate TOC from h2 headings -->
  <script>
    const content = document.getElementById('sovn-content');
    const tocNav = document.getElementById('toc-nav');
    if (content && tocNav) {
      const headings = content.querySelectorAll('h2');
      if (headings.length > 0) {
        const list = document.createElement('ul');
        list.className = 'toc-list';
        headings.forEach((h, i) => {
          const id = h.id || `section-${i}`;
          h.id = id;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = h.textContent || '';
          a.className = 'toc-link';
          li.appendChild(a);
          list.appendChild(li);
        });
        tocNav.appendChild(list);

        const links = tocNav.querySelectorAll('.toc-link');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('toc-active'));
              const activeLink = tocNav.querySelector(`a[href="#${entry.target.id}"]`);
              if (activeLink) activeLink.classList.add('toc-active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        headings.forEach(h => observer.observe(h));
      } else {
        const toc = document.getElementById('sovn-toc');
        if (toc) toc.style.display = 'none';
      }
    }
  </script>
</Base>

<style>
  .sovn-article {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .sovn-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 32px;
    padding-top: 8px;
  }
  .sovn-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .sovn-breadcrumb a:hover {
    color: #1D9E75;
    text-decoration: none;
  }
  .sovn-sep { color: var(--color-text-muted); opacity: 0.5; }
  .sovn-current { color: var(--color-text-heading); font-weight: 600; }

  /* Header */
  .sovn-header {
    margin-bottom: 32px;
  }
  .sovn-badge {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 16px;
    border: 1px solid;
  }
  .sovn-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 12px;
  }
  .sovn-meta {
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .sovn-title {
    font-family: var(--font-heading);
    font-size: 40px;
    line-height: 1.2;
    color: var(--color-text-heading);
    margin-bottom: 16px;
    font-weight: 700;
  }
  @media (min-width: 768px) {
    .sovn-title { font-size: 48px; }
  }
  .sovn-intro {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 640px;
  }

  /* Image */
  .sovn-image-wrapper {
    margin-bottom: 40px;
  }
  .sovn-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--border-radius-card);
    box-shadow: var(--box-shadow-card);
  }

  /* 2-column layout */
  .sovn-layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .sovn-layout {
      flex-direction: row;
      gap: 48px;
    }
  }

  /* TOC sidebar */
  .sovn-toc {
    display: none;
  }
  @media (min-width: 768px) {
    .sovn-toc {
      display: block;
      width: 220px;
      flex-shrink: 0;
      position: sticky;
      top: 100px;
      align-self: flex-start;
      max-height: calc(100vh - 140px);
      overflow-y: auto;
    }
  }

  .toc-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    font-weight: 600;
  }

  :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 2px solid rgba(29, 158, 117, 0.2);
  }

  :global(.toc-link) {
    display: block;
    padding: 6px 0 6px 16px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    border-left: 2px solid transparent;
    margin-left: -2px;
  }
  :global(.toc-link:hover) {
    color: #1D9E75;
    text-decoration: none;
  }
  :global(.toc-link.toc-active) {
    color: #1D9E75;
    border-left-color: #1D9E75;
    font-weight: 600;
  }

  /* Content takes remaining space */
  .sovn-content {
    flex: 1;
    min-width: 0;
  }

  /* Related boxes */
  .sovn-related {
    margin-top: 48px;
    padding: 24px;
    background: rgba(29, 158, 117, 0.04);
    border: 1px solid rgba(29, 158, 117, 0.15);
    border-radius: var(--border-radius-card);
  }
  .sovn-related-drommer {
    background: rgba(123, 111, 160, 0.04);
    border-color: rgba(123, 111, 160, 0.15);
  }
  .sovn-related-title {
    font-family: var(--font-nav);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    font-weight: 600;
    border: none;
    padding: 0;
  }
  .sovn-related-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sovn-related-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }
  .sovn-related-card:hover {
    background: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  .sovn-related-card-dream:hover {
    background: rgba(255, 255, 255, 0.9);
  }
  .sovn-related-badge {
    font-family: var(--font-nav);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .sovn-related-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-heading);
  }
</style>
