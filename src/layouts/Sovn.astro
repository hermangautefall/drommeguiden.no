---
import Base from './Base.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';
import { getCollection } from 'astro:content';
import { defaultLang, languages, type Lang } from '../i18n/config';
import { pathFor, homePath } from '../i18n/utils';

interface AlternateLink {
  lang: Lang;
  url: string;
}

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  slug: string;
  kategori: string;
  leseminutter: number;
  dato: Date;
  oppdatert?: Date;
  bilde?: string;
  relaterte_sovn?: string[];
  relaterte_drommer?: string[];
  lang?: Lang;
  alternates?: AlternateLink[];
}

const { tittel, kortbeskrivelse, slug, kategori, leseminutter, dato, oppdatert, bilde, relaterte_sovn, relaterte_drommer, lang = defaultLang, alternates = [] } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;
const langConfig = languages[lang];

const kategoriMapNb: Record<string, { label: string; color: string; bg: string }> = {
  vitenskap: { label: 'Søvnvitenskap', color: '#7B6FA0', bg: 'rgba(123, 111, 160, 0.1)' },
  hygiene: { label: 'Søvnhygiene', color: '#1D9E75', bg: 'rgba(29, 158, 117, 0.1)' },
  lidelser: { label: 'Søvnlidelser', color: '#C07050', bg: 'rgba(192, 112, 80, 0.1)' },
  livsfaser: { label: 'Livsfaser', color: '#4A8BBF', bg: 'rgba(74, 139, 191, 0.1)' },
  produkter: { label: 'Produkter', color: '#B8960C', bg: 'rgba(184, 150, 12, 0.1)' },
  psykologi: { label: 'Søvnpsykologi', color: '#9B7FBF', bg: 'rgba(155, 127, 191, 0.1)' },
};
const kategoriMapSv: Record<string, { label: string; color: string; bg: string }> = {
  vitenskap: { label: 'Sömnvetenskap', color: '#7B6FA0', bg: 'rgba(123, 111, 160, 0.1)' },
  hygiene: { label: 'Sömnhygien', color: '#1D9E75', bg: 'rgba(29, 158, 117, 0.1)' },
  lidelser: { label: 'Sömnstörningar', color: '#C07050', bg: 'rgba(192, 112, 80, 0.1)' },
  livsfaser: { label: 'Livsfaser', color: '#4A8BBF', bg: 'rgba(74, 139, 191, 0.1)' },
  produkter: { label: 'Produkter', color: '#B8960C', bg: 'rgba(184, 150, 12, 0.1)' },
  psykologi: { label: 'Sömnpsykologi', color: '#9B7FBF', bg: 'rgba(155, 127, 191, 0.1)' },
};
const kategoriMap = lang === 'sv' ? kategoriMapSv : kategoriMapNb;
const kat = kategoriMap[kategori] || kategoriMap.vitenskap;

const labels = lang === 'sv'
  ? { hjem: 'Hem', sovn: 'Sömn', breadcrumb: 'Brödsmulor', lesetid: 'min läsning', oppdatert: 'Uppdaterad', innhold: 'Innehåll', relatert: 'Relaterat', lesMer: 'Läs mer om sömn', fraGuiden: 'Från drömguiden', drommerOgSovn: 'Drömmar och sömn', guideLabel: 'Guide', dateLocale: 'sv-SE' }
  : { hjem: 'Hjem', sovn: 'Søvn', breadcrumb: 'Brødsmuler', lesetid: 'min lesetid', oppdatert: 'Oppdatert', innhold: 'Innhold', relatert: 'Relatert', lesMer: 'Les mer om søvn', fraGuiden: 'Fra drømmeguiden', drommerOgSovn: 'Drømmer og søvn', guideLabel: 'Guide', dateLocale: 'nb-NO' };

const sovnCollection = lang === 'sv' ? 'sovn-sv' : 'sovn';
const guiderCollection = lang === 'sv' ? 'guider-sv' : 'guider';

const alleSovn = await getCollection(sovnCollection as any);
const relaterteSovnArtikler = (relaterte_sovn || [])
  .map(s => alleSovn.find((a: any) => a.data.slug === s))
  .filter(Boolean);

const alleGuider = await getCollection(guiderCollection as any);
const relaterteDrommerArtikler = (relaterte_drommer || [])
  .map(s => alleGuider.find((g: any) => g.data.slug === s))
  .filter(Boolean);

const baseSite = 'https://drommeguiden.no';
const canonical = `${baseSite}${pathFor(lang, 'sovn', slug)}`;
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={canonical} lang={lang} alternates={alternates}>
  <article class="sovn-article">
    <!-- Breadcrumb -->
    <nav class="sovn-breadcrumb" aria-label={labels.breadcrumb}>
      <a href={homePath(lang)}>{labels.hjem}</a>
      <span class="sovn-sep" aria-hidden="true">/</span>
      <a href={pathFor(lang, 'sovn')}>{labels.sovn}</a>
      <span class="sovn-sep" aria-hidden="true">/</span>
      <span class="sovn-current">{tittel}</span>
    </nav>

    <!-- Header -->
    <header class="sovn-header">
      <span class="sovn-badge" style={`color: ${kat.color}; background: ${kat.bg};`}>
        {kat.label}
      </span>
      <div class="sovn-meta-row">
        <span class="sovn-meta">{leseminutter} {labels.lesetid}</span>
        {oppdatert && (
          <span class="sovn-meta">{labels.oppdatert} {oppdatert.toLocaleDateString(labels.dateLocale, { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        )}
      </div>
      <h1 class="sovn-title">{tittel}</h1>
      <p class="sovn-intro">{kortbeskrivelse}</p>
    </header>

    {bilde && (
      <div class="sovn-image-wrapper">
        <img src={bilde} alt={tittel} class="sovn-image" loading="eager" />
        {bildeFilnavn && <BildeKreditt filnavn={bildeFilnavn} />}
      </div>
    )}

    <!-- 2-column: TOC sidebar + content -->
    <div class="sovn-layout">
      <aside class="sovn-toc" id="sovn-toc">
        <p class="toc-label">{labels.innhold}</p>
        <nav id="toc-nav" aria-label={labels.innhold}></nav>
      </aside>

      <div class="sovn-content prose" id="sovn-content">
        <slot />

        <!-- Related sovn articles -->
        {relaterteSovnArtikler.length > 0 && (
          <div class="sovn-related">
            <span class="sovn-related-label">{labels.relatert}</span>
            <h3 class="sovn-related-title">{labels.lesMer}</h3>
            <div class="sovn-related-grid">
              {relaterteSovnArtikler.map((art: any) => {
                const artKat = kategoriMap[art.data.kategori] || kategoriMap.vitenskap;
                return (
                  <a href={pathFor(lang, 'sovn', art.data.slug)} class="sovn-related-card">
                    <span class="sovn-related-badge" style={`color: ${artKat.color};`}>{artKat.label}</span>
                    <span class="sovn-related-name">{art.data.tittel}</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Related dream content -->
        {relaterteDrommerArtikler.length > 0 && (
          <div class="sovn-related sovn-related-drommer">
            <span class="sovn-related-label">{labels.fraGuiden}</span>
            <h3 class="sovn-related-title">{labels.drommerOgSovn}</h3>
            <div class="sovn-related-grid">
              {relaterteDrommerArtikler.map((art: any) => (
                <a href={pathFor(lang, 'guider', art.data.slug)} class="sovn-related-card">
                  <span class="sovn-related-badge" style="color: var(--color-accent);">{labels.guideLabel}</span>
                  <span class="sovn-related-name">{art.data.tittel}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <Kommentarer />
      </div>
    </div>
  </article>

  <!-- Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: tittel,
      description: kortbeskrivelse,
      datePublished: dato.toISOString(),
      ...(oppdatert && { dateModified: oppdatert.toISOString() }),
      inLanguage: langConfig.htmlLang,
      url: canonical,
      ...(bilde && { image: `${baseSite}${bilde}` }),
      publisher: {
        '@type': 'Organization',
        name: langConfig.brand,
        url: baseSite,
      },
    })}
  />

  <!-- Auto-generate TOC from h2 headings -->
  <script>
    const content = document.getElementById('sovn-content');
    const tocNav = document.getElementById('toc-nav');
    if (content && tocNav) {
      const headings = content.querySelectorAll('h2');
      if (headings.length > 0) {
        const list = document.createElement('ul');
        list.className = 'toc-list';
        headings.forEach((h, i) => {
          const id = h.id || `section-${i}`;
          h.id = id;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = h.textContent || '';
          a.className = 'toc-link';
          li.appendChild(a);
          list.appendChild(li);
        });
        tocNav.appendChild(list);

        const links = tocNav.querySelectorAll('.toc-link');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('toc-active'));
              const activeLink = tocNav.querySelector(`a[href="#${entry.target.id}"]`);
              if (activeLink) activeLink.classList.add('toc-active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        headings.forEach(h => observer.observe(h));
      } else {
        const toc = document.getElementById('sovn-toc');
        if (toc) toc.style.display = 'none';
      }
    }
  </script>
</Base>

<style>
  .sovn-article {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .sovn-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 32px;
    padding-top: 8px;
  }
  .sovn-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .sovn-breadcrumb a:hover {
    color: #1D9E75;
    text-decoration: none;
  }
  .sovn-sep { color: var(--color-text-muted); opacity: 0.35; font-size: 11px; }
  .sovn-current { color: var(--color-text-body); }

  /* Header */
  .sovn-header {
    margin-bottom: 36px;
  }
  .sovn-badge {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 16px;
  }
  .sovn-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 14px;
  }
  .sovn-meta {
    font-family: var(--font-nav);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.3px;
  }
  .sovn-title {
    font-family: var(--font-heading);
    font-size: 40px;
    line-height: 1.15;
    color: var(--color-text-heading);
    margin-bottom: 16px;
    font-weight: 400;
  }
  @media (min-width: 768px) {
    .sovn-title { font-size: 48px; }
  }
  .sovn-intro {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  /* Image */
  .sovn-image-wrapper {
    margin-bottom: 40px;
  }
  .sovn-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 16px;
  }

  /* 2-column layout */
  .sovn-layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .sovn-layout {
      flex-direction: row;
      gap: 48px;
    }
  }

  /* TOC sidebar */
  .sovn-toc {
    display: none;
  }
  @media (min-width: 768px) {
    .sovn-toc {
      display: block;
      width: 200px;
      flex-shrink: 0;
      position: sticky;
      top: 100px;
      align-self: flex-start;
      max-height: calc(100vh - 140px);
      overflow-y: auto;
    }
  }

  .toc-label {
    font-family: var(--font-nav);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    font-weight: 600;
  }

  :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid rgba(29, 158, 117, 0.15);
  }

  :global(.toc-link) {
    display: block;
    padding: 6px 0 6px 16px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }
  :global(.toc-link:hover) {
    color: #1D9E75;
    text-decoration: none;
  }
  :global(.toc-link.toc-active) {
    color: #1D9E75;
    border-left-color: #1D9E75;
    font-weight: 600;
  }

  .sovn-content {
    flex: 1;
    min-width: 0;
  }

  /* Green prose overrides for søvn articles */
  .sovn-content :global(h2) {
    border-left-color: #1D9E75;
  }
  .sovn-content :global(a) {
    color: #1D9E75;
    text-decoration-color: rgba(29, 158, 117, 0.3);
  }
  .sovn-content :global(a:hover) {
    text-decoration-color: #1D9E75;
  }

  /* Related boxes */
  .sovn-related {
    margin-top: 56px;
    padding: 28px;
    background: rgba(29, 158, 117, 0.04);
    border: 1px solid rgba(29, 158, 117, 0.1);
    border-radius: 16px;
  }
  .sovn-related-drommer {
    background: rgba(123, 111, 160, 0.04);
    border-color: rgba(123, 111, 160, 0.1);
  }

  .sovn-related-label {
    display: block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }

  .sovn-related-title {
    font-family: var(--font-heading);
    font-size: 24px;
    color: var(--color-text-heading);
    margin-bottom: 18px;
    font-weight: 400;
    border: none;
    padding: 0;
  }
  .sovn-related-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sovn-related-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .sovn-related-card:hover {
    background: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
  .sovn-related-badge {
    font-family: var(--font-nav);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .sovn-related-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-heading);
  }
</style>
