---
import Base from './Base.astro';
import TLDRBoks from '../components/TLDRBoks.astro';
import RelaterteBoks from '../components/RelaterteBoks.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';
import { defaultLang, languages, type Lang } from '../i18n/config';
import { pathFor, homePath } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface AlternateLink {
  lang: Lang;
  url: string;
}

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  tolkninger_kort: string[];
  relaterte: string[];
  slug: string;
  kategori: string;
  dato: Date;
  bilde?: string;
  lang?: Lang;
  alternates?: AlternateLink[];
}

const { tittel, kortbeskrivelse, tolkninger_kort, relaterte, slug, kategori, dato, bilde, lang = defaultLang, alternates = [] } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;
const displayTitle = tittel.replace(/ — hva betyr det\?/, '').replace(/^Drömmar om /i, '').replace(/^Drømmer om /i, '');
const kategoriTittel = kategori.charAt(0).toUpperCase() + kategori.slice(1);
const t = useTranslations(lang);
const langConfig = languages[lang];

const baseSite = 'https://drommeguiden.no';
const canonical = `${baseSite}${pathFor(lang, 'drommer', slug)}`;

const labels = lang === 'sv'
  ? { hjem: 'Hem', symboler: 'Symboler', breadcrumb: 'Brödsmulor' }
  : { hjem: 'Hjem', symboler: 'Symboler', breadcrumb: 'Brødsmuler' };
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={canonical} lang={lang} alternates={alternates}>
  <article class="symbol-article">
    <!-- Hero -->
    <div class="symbol-hero">
      {bilde && (
        <div class="symbol-hero-bg">
          <img src={bilde} alt={displayTitle} loading="eager" />
          <div class="symbol-hero-overlay"></div>
        </div>
      )}
      <div class="symbol-hero-content">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label={labels.breadcrumb}>
          <a href={homePath(lang)}>{labels.hjem}</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <a href={pathFor(lang, 'drommer')}>{t('nav.symboler')}</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <a href={pathFor(lang, 'kategori', kategori)}>{kategoriTittel}</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span class="breadcrumb-current">{displayTitle}</span>
        </nav>

        <span class="symbol-kategori-badge">{kategoriTittel}</span>
        <h1 class="symbol-title">{tittel}</h1>
        <p class="symbol-intro">{kortbeskrivelse}</p>
      </div>
      {bilde && bildeFilnavn && (
        <div class="symbol-hero-credit">
          <BildeKreditt filnavn={bildeFilnavn} />
        </div>
      )}
    </div>

    <!-- Wave transition -->
    <div class="symbol-wave" aria-hidden="true">
      <svg viewBox="0 0 1200 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 60 C200 20 400 40 600 25 C800 10 1000 35 1200 15 L1200 0 L0 0Z" fill="var(--color-bg-cream)" opacity="0.5"/>
        <path d="M0 60 C150 35 350 50 550 30 C750 10 950 45 1200 20 L1200 0 L0 0Z" fill="var(--color-bg-cream)"/>
      </svg>
    </div>

    <!-- Content area -->
    <div class="symbol-content">
      <TLDRBoks tolkninger={tolkninger_kort} lang={lang} />

      <div class="prose">
        <slot />
      </div>

      <RelaterteBoks relaterte={relaterte || []} lang={lang} />
      <Kommentarer />
    </div>
  </article>

  <!-- FAQPage + Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Article',
          headline: tittel,
          description: kortbeskrivelse,
          datePublished: dato.toISOString(),
          inLanguage: langConfig.htmlLang,
          url: canonical,
          ...(bilde && { image: `${baseSite}${bilde}` }),
          publisher: {
            '@type': 'Organization',
            name: langConfig.brand,
            url: baseSite,
          },
        },
        {
          '@type': 'FAQPage',
          inLanguage: langConfig.htmlLang,
          mainEntity: tolkninger_kort.map((tolkning) => ({
            '@type': 'Question',
            name: lang === 'sv'
              ? `Vad betyder det att drömma om ${slug.replace(/-/g, ' ')}?`
              : `Hva betyr det å drømme om ${slug.replace(/-/g, ' ')}?`,
            acceptedAnswer: {
              '@type': 'Answer',
              text: tolkning,
            },
          })),
        },
      ],
    })}
  />
</Base>

<style>
  .symbol-article {
    margin: -40px -16px 0;
  }
  @media (min-width: 768px) {
    .symbol-article {
      margin: -40px -24px 0;
    }
  }

  /* ========== HERO ========== */
  .symbol-hero {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .symbol-hero {
      min-height: 440px;
    }
  }

  .symbol-hero-bg {
    position: absolute;
    inset: 0;
  }
  .symbol-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .symbol-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15, 19, 40, 0.92) 0%,
      rgba(15, 19, 40, 0.6) 40%,
      rgba(15, 19, 40, 0.25) 70%,
      rgba(15, 19, 40, 0.1) 100%
    );
  }

  .symbol-hero-content {
    position: relative;
    z-index: 2;
    padding: 100px 24px 48px;
    max-width: 720px;
    animation: fadeInUp 0.5s ease-out both;
  }
  @media (min-width: 768px) {
    .symbol-hero-content {
      padding: 140px 48px 56px;
    }
  }

  .symbol-hero-credit {
    position: absolute;
    bottom: 12px;
    right: 16px;
    z-index: 3;
    opacity: 0.5;
    font-size: 11px;
  }

  /* ========== WAVE TRANSITION ========== */
  .symbol-wave {
    margin-top: -30px;
    position: relative;
    z-index: 3;
  }
  .symbol-wave svg {
    display: block;
    width: 100%;
    height: 40px;
  }

  /* ========== BREADCRUMB ========== */
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 24px;
  }
  .breadcrumb a {
    color: rgba(242, 237, 230, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover {
    color: rgba(242, 237, 230, 0.9);
    text-decoration: none;
  }
  .breadcrumb-sep {
    color: rgba(242, 237, 230, 0.25);
    font-size: 11px;
  }
  .breadcrumb-current {
    color: rgba(242, 237, 230, 0.75);
  }

  /* ========== BADGE ========== */
  .symbol-kategori-badge {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(192, 128, 112, 0.15);
    padding: 5px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 16px;
  }

  /* ========== TITLE & INTRO ========== */
  .symbol-title {
    font-family: var(--font-heading);
    font-size: 36px;
    line-height: 1.15;
    color: #f2ede6;
    margin-bottom: 14px;
    font-weight: 400;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }
  @media (min-width: 768px) {
    .symbol-title {
      font-size: 48px;
    }
  }

  .symbol-intro {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.7);
    max-width: 540px;
  }

  /* ========== CONTENT AREA ========== */
  .symbol-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px 0;
  }
  @media (min-width: 768px) {
    .symbol-content {
      padding: 48px 0 0;
    }
  }

  /* ========== NO-IMAGE FALLBACK ========== */
  .symbol-hero:not(:has(.symbol-hero-bg)) {
    background: linear-gradient(
      160deg,
      #0f1328 0%,
      #1a2340 40%,
      #0f2030 100%
    );
    min-height: 300px;
  }
  @media (min-width: 768px) {
    .symbol-hero:not(:has(.symbol-hero-bg)) {
      min-height: 360px;
    }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
