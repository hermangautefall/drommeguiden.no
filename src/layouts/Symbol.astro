---
import Base from './Base.astro';
import TLDRBoks from '../components/TLDRBoks.astro';
import RelaterteBoks from '../components/RelaterteBoks.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  tolkninger_kort: string[];
  relaterte: string[];
  slug: string;
  kategori: string;
  dato: Date;
  bilde?: string;
}

const { tittel, kortbeskrivelse, tolkninger_kort, relaterte, slug, kategori, dato, bilde } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;
const displayTitle = tittel.replace(/ — hva betyr det\?/, '').replace('Drømmer om ', '');
const kategoriTittel = kategori.charAt(0).toUpperCase() + kategori.slice(1);
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={`https://drommeguiden.no/drommer/${slug}`}>
  <article class="symbol-article">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Brødsmuler">
      <a href="/">Hjem</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/drommer">Symboler</a>
      <span class="breadcrumb-sep">›</span>
      <a href={`/kategori/${kategori}`}>{kategoriTittel}</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">{displayTitle}</span>
    </nav>

    <!-- Hero: 2-column with image -->
    <header class="symbol-hero">
      <div class="symbol-hero-text">
        <span class="symbol-kategori-badge">{kategoriTittel}</span>
        <h1 class="symbol-title">{tittel}</h1>
        <p class="symbol-intro">{kortbeskrivelse}</p>
      </div>
      {bilde && (
        <div class="symbol-hero-image">
          <img src={bilde} alt={displayTitle} loading="eager" />
          {bildeFilnavn && <BildeKreditt filnavn={bildeFilnavn} />}
        </div>
      )}
    </header>

    <!-- TL;DR box -->
    <TLDRBoks tolkninger={tolkninger_kort} />

    <!-- Ezoic ad placement: after TL;DR -->
    <!-- <div id="ezoic-pub-ad-placeholder-101"></div> -->

    <!-- Article body -->
    <div class="prose">
      <slot />
    </div>

    <!-- Ezoic ad placement: after content -->
    <!-- <div id="ezoic-pub-ad-placeholder-102"></div> -->

    <!-- Related symbols -->
    <RelaterteBoks relaterte={relaterte || []} />

    <!-- Ezoic ad placement: after related symbols -->
    <!-- <div id="ezoic-pub-ad-placeholder-103"></div> -->

    <!-- Comments -->
    <Kommentarer />
  </article>

  <!-- FAQPage + Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Article',
          headline: tittel,
          description: kortbeskrivelse,
          datePublished: dato.toISOString(),
          url: `https://drommeguiden.no/drommer/${slug}`,
          ...(bilde && { image: `https://drommeguiden.no${bilde}` }),
          publisher: {
            '@type': 'Organization',
            name: 'Drømmeguiden',
            url: 'https://drommeguiden.no',
          },
        },
        {
          '@type': 'FAQPage',
          mainEntity: tolkninger_kort.map((tolkning) => ({
            '@type': 'Question',
            name: `Hva betyr det å drømme om ${slug.replace(/-/g, ' ')}?`,
            acceptedAnswer: {
              '@type': 'Answer',
              text: tolkning,
            },
          })),
        },
      ],
    })}
  />
</Base>

<style>
  .symbol-article {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 32px;
    padding-top: 8px;
  }
  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .breadcrumb-sep {
    color: var(--color-text-muted);
    opacity: 0.5;
  }
  .breadcrumb-current {
    color: var(--color-text-heading);
    font-weight: 600;
  }

  /* Hero */
  .symbol-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .symbol-hero {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .symbol-hero-text {
    order: 2;
  }
  @media (min-width: 768px) {
    .symbol-hero-text {
      order: 1;
    }
  }

  .symbol-kategori-badge {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-light);
    padding: 6px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 16px;
  }

  .symbol-title {
    font-family: var(--font-heading);
    font-size: 36px;
    line-height: 1.2;
    color: var(--color-text-heading);
    margin-bottom: 16px;
    font-weight: 700;
  }
  @media (min-width: 768px) {
    .symbol-title {
      font-size: 44px;
    }
  }

  .symbol-intro {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .symbol-hero-image {
    order: 1;
  }
  @media (min-width: 768px) {
    .symbol-hero-image {
      order: 2;
    }
  }
  .symbol-hero-image img {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: var(--border-radius-card);
    box-shadow: var(--box-shadow-card);
  }
</style>
