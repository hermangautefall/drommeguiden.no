---
import Base from './Base.astro';
import TLDRBoks from '../components/TLDRBoks.astro';
import RelaterteBoks from '../components/RelaterteBoks.astro';
import BildeKreditt from '../components/BildeKreditt.astro';
import Kommentarer from '../components/Kommentarer.astro';

interface Props {
  tittel: string;
  kortbeskrivelse: string;
  tolkninger_kort: string[];
  relaterte: string[];
  slug: string;
  kategori: string;
  dato: Date;
  bilde?: string;
}

const { tittel, kortbeskrivelse, tolkninger_kort, relaterte, slug, kategori, dato, bilde } = Astro.props;
const bildeFilnavn = bilde ? bilde.split('/').pop() : undefined;
const displayTitle = tittel.replace(/ — hva betyr det\?/, '').replace('Drømmer om ', '');
const kategoriTittel = kategori.charAt(0).toUpperCase() + kategori.slice(1);
---

<Base tittel={tittel} beskrivelse={kortbeskrivelse} canonicalUrl={`https://drommeguiden.no/drommer/${slug}`}>
  <article class="symbol-article">
    <!-- Immersive Hero -->
    <div class="symbol-hero">
      {bilde && (
        <div class="symbol-hero-bg">
          <img src={bilde} alt={displayTitle} loading="eager" />
          <div class="symbol-hero-overlay"></div>
        </div>
      )}
      <div class="symbol-hero-content">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Brødsmuler">
          <a href="/">Hjem</a>
          <span class="breadcrumb-sep">›</span>
          <a href="/drommer">Symboler</a>
          <span class="breadcrumb-sep">›</span>
          <a href={`/kategori/${kategori}`}>{kategoriTittel}</a>
          <span class="breadcrumb-sep">›</span>
          <span class="breadcrumb-current">{displayTitle}</span>
        </nav>

        <span class="symbol-kategori-badge">{kategoriTittel}</span>
        <h1 class="symbol-title">{tittel}</h1>
        <p class="symbol-intro">{kortbeskrivelse}</p>
      </div>
      {bilde && bildeFilnavn && (
        <div class="symbol-hero-credit">
          <BildeKreditt filnavn={bildeFilnavn} />
        </div>
      )}
    </div>

    <!-- Content area -->
    <div class="symbol-content">
      <!-- TL;DR box -->
      <TLDRBoks tolkninger={tolkninger_kort} />

      <!-- Article body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Related symbols -->
      <RelaterteBoks relaterte={relaterte || []} />

      <!-- Comments -->
      <Kommentarer />
    </div>
  </article>

  <!-- FAQPage + Article schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Article',
          headline: tittel,
          description: kortbeskrivelse,
          datePublished: dato.toISOString(),
          url: `https://drommeguiden.no/drommer/${slug}`,
          ...(bilde && { image: `https://drommeguiden.no${bilde}` }),
          publisher: {
            '@type': 'Organization',
            name: 'Drømmeguiden',
            url: 'https://drommeguiden.no',
          },
        },
        {
          '@type': 'FAQPage',
          mainEntity: tolkninger_kort.map((tolkning) => ({
            '@type': 'Question',
            name: `Hva betyr det å drømme om ${slug.replace(/-/g, ' ')}?`,
            acceptedAnswer: {
              '@type': 'Answer',
              text: tolkning,
            },
          })),
        },
      ],
    })}
  />
</Base>

<style>
  /* ========== IMMERSIVE HERO ========== */
  .symbol-hero {
    position: relative;
    margin: -32px -24px 0;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-radius: 0 0 24px 24px;
  }
  @media (min-width: 768px) {
    .symbol-hero {
      margin: -32px -48px 0;
      min-height: 420px;
      border-radius: 0 0 32px 32px;
    }
  }

  .symbol-hero-bg {
    position: absolute;
    inset: 0;
  }
  .symbol-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .symbol-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15, 19, 40, 0.92) 0%,
      rgba(15, 19, 40, 0.65) 40%,
      rgba(15, 19, 40, 0.3) 70%,
      rgba(15, 19, 40, 0.15) 100%
    );
  }

  .symbol-hero-content {
    position: relative;
    z-index: 2;
    padding: 80px 24px 40px;
    max-width: 700px;
    animation: fadeInUp 0.6s ease-out both;
  }
  @media (min-width: 768px) {
    .symbol-hero-content {
      padding: 120px 48px 48px;
    }
  }

  .symbol-hero-credit {
    position: absolute;
    bottom: 12px;
    right: 16px;
    z-index: 3;
    opacity: 0.6;
    font-size: 11px;
  }
  @media (min-width: 768px) {
    .symbol-hero-credit {
      bottom: 16px;
      right: 24px;
    }
  }

  /* ========== BREADCRUMB ========== */
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-nav);
    margin-bottom: 24px;
  }
  .breadcrumb a {
    color: rgba(242, 237, 230, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover {
    color: rgba(242, 237, 230, 0.9);
    text-decoration: none;
  }
  .breadcrumb-sep {
    color: rgba(242, 237, 230, 0.3);
  }
  .breadcrumb-current {
    color: rgba(242, 237, 230, 0.8);
    font-weight: 600;
  }

  /* ========== BADGE ========== */
  .symbol-kategori-badge {
    display: inline-block;
    font-family: var(--font-nav);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(192, 128, 112, 0.15);
    padding: 5px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 16px;
    border: 1px solid rgba(192, 128, 112, 0.25);
  }

  /* ========== TITLE & INTRO ========== */
  .symbol-title {
    font-family: var(--font-heading);
    font-size: 34px;
    line-height: 1.15;
    color: #f2ede6;
    margin-bottom: 14px;
    font-weight: 700;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }
  @media (min-width: 768px) {
    .symbol-title {
      font-size: 46px;
    }
  }

  .symbol-intro {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(242, 237, 230, 0.75);
    max-width: 560px;
  }

  /* ========== CONTENT AREA ========== */
  .symbol-content {
    max-width: 760px;
    margin: 0 auto;
    padding-top: 40px;
  }
  @media (min-width: 768px) {
    .symbol-content {
      padding-top: 56px;
    }
  }

  /* ========== NO-IMAGE FALLBACK ========== */
  .symbol-hero:not(:has(.symbol-hero-bg)) {
    background: linear-gradient(
      135deg,
      var(--color-bg-dark) 0%,
      rgba(123, 111, 160, 0.3) 50%,
      var(--color-bg-dark) 100%
    );
    min-height: 280px;
  }
  @media (min-width: 768px) {
    .symbol-hero:not(:has(.symbol-hero-bg)) {
      min-height: 340px;
    }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
